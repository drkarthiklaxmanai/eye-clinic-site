---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const pageTitle = "Eye Health Blog";
const pageDescription = "Patient guides and clinical insights on cataracts, LASIK, retina care, glaucoma, and more from Dr. Rajeswari at Crispr Eye Care, Chennai.";

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
---

<MainLayout title={pageTitle} description={pageDescription}>
  <section class="bg-blue-900 text-white py-16 px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Eye Health Blog</h1>
      <p class="text-xl text-blue-200">Patient guides and clinical insights from Dr. Rajeswari.</p>
    </div>
  </section>

  <section class="py-16 px-6 max-w-7xl mx-auto">
    {sortedPosts.length === 0 ? (
      <p class="text-center text-slate-600 text-lg">No articles published yet. Check back soon.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {sortedPosts.map((post) => (
          <a href={`/blog/${post.slug}`} class="bg-white rounded-2xl shadow-sm border border-slate-100 hover:shadow-xl hover:border-blue-200 transition-all duration-300 group flex flex-col h-full p-6 md:p-8 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-blue-600 group-hover:bg-blue-700 transition-colors"></div>
            <p class="text-xs text-blue-600 mb-3 font-bold uppercase tracking-wider">
              {new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              {post.data.tags && post.data.tags.length > 0 && (
                <span class="text-slate-400"> &middot; {post.data.tags[0]}</span>
              )}
            </p>
            <h2 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-blue-600 transition-colors line-clamp-2">
              {post.data.title}
            </h2>
            <p class="text-slate-600 text-sm mb-6 line-clamp-3 flex-grow leading-relaxed">
              {post.data.description}
            </p>
            <span class="text-blue-600 font-semibold text-sm mt-auto flex items-center gap-1 group-hover:gap-2 transition-all">
              Read Article <span aria-hidden="true">→</span>
            </span>
          </a>
        ))}
      </div>
    )}
  </section>
</MainLayout>

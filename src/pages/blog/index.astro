---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// Fetch all blog posts and sort by date descending
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => 
  new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
---

<MainLayout title="Eye Care Blog | Crispr Eye Care">
  <div class="bg-blue-50 py-16 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl font-extrabold text-blue-900 mb-4">Eye Health Blog</h1>
      <p class="text-lg text-slate-700">Patient guides, FAQs, and medical insights from Dr. Rajeswari.</p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto py-16 px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {sortedPosts.map((post) => (
        <a href={`/blog/${post.slug}`} class="block bg-white rounded-xl shadow-sm border border-slate-200 p-8 hover:shadow-md hover:border-blue-300 transition group">
          <p class="text-sm text-slate-500 mb-3">{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-3 group-hover:text-blue-600 transition">{post.data.title}</h2>
          <p class="text-slate-600 mb-4 line-clamp-2">{post.data.description}</p>
          <span class="text-blue-600 font-semibold">Read Article &rarr;</span>
        </a>
      ))}
    </div>
  </div>
</MainLayout>


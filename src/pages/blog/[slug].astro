---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<MainLayout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-3xl mx-auto py-16 px-6">
    <div class="mb-8">
      <h1 class="text-4xl font-extrabold text-blue-900 mb-4">{entry.data.title}</h1>
      <p class="text-slate-500 font-medium">
        By {entry.data.author} • {entry.data.pubDate.toDateString()}
      </p>
    </div>
    
    <div class="prose prose-slate prose-blue max-w-none">
      <Content />
    </div>
  </article>
</MainLayout>


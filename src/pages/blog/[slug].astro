---
import { getCollection, getEntry } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
const { Content } = await entry.render();

const relatedCondition = entry.data.condition
  ? await getEntry('conditions', entry.data.condition)
  : null;
const relatedService = entry.data.service
  ? await getEntry('services', entry.data.service)
  : null;
---

<MainLayout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-3xl mx-auto py-16 px-6">
    <div class="mb-8">
      <h1 class="text-4xl font-extrabold text-blue-900 mb-4">{entry.data.title}</h1>
      <p class="text-slate-500 font-medium">
        By {entry.data.author || 'Dr. Rajeswari'} 
        {entry.data.pubDate && ` • ${new Date(entry.data.pubDate).toDateString()}`}
      </p>
    </div>
    
    <div class="prose prose-slate prose-blue max-w-none">
      <Content />
    </div>

    {(relatedCondition || relatedService) && (
      <div class="mt-12 pt-8 border-t border-slate-200">
        <h2 class="text-lg font-bold text-blue-900 mb-4">Related Reading</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {relatedCondition && (
            <a href={`/conditions/${relatedCondition.slug}`} class="block p-5 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
              <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Condition</p>
              <p class="font-semibold text-slate-900">{relatedCondition.data.title}</p>
            </a>
          )}
          {relatedService && (
            <a href={`/services/${relatedService.slug}`} class="block p-5 rounded-xl bg-blue-50 hover:bg-blue-100 transition-colors">
              <p class="text-xs text-blue-600 font-bold uppercase tracking-wider mb-1">Service</p>
              <p class="font-semibold text-slate-900">{relatedService.data.title}</p>
            </a>
          )}
        </div>
      </div>
    )}
  </article>
</MainLayout>


---
import { getCollection, getEntry } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import CTA from '../../components/CTA.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { siteConfig } from '../../config/site.js';

export async function getStaticPaths() {
  const conditions = await getCollection('conditions');
  return conditions.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

const parentService = await getEntry('services', data.parentService);
const relatedConditionEntries = data.relatedConditions
  ? await Promise.all(
      data.relatedConditions.map((slug) => getEntry('conditions', slug))
    )
  : [];

// Resolve faqIds against the central faqs collection.
let faqEntries = [];
if (data.faqIds && data.faqIds.length > 0) {
  const resolved = await Promise.all(
    data.faqIds.map((id) => getEntry('faqs', id))
  );
  faqEntries = resolved
    .filter(Boolean)
    .map((f) => ({ question: f.data.question, answer: f.body }));
}
---

<MainLayout title={data.title} description={data.metaDescription}>
  <Breadcrumbs items={[
    { name: "Services", url: "/#services" },
    ...(parentService ? [{ name: parentService.data.title, url: `/services/${parentService.slug}` }] : []),
    { name: data.title, url: `/conditions/${entry.slug}` }
  ]} />

  <section class="bg-blue-900 text-white py-20 px-6">
    <div class="max-w-7xl mx-auto">
      {data.heroEyebrow && (
        <span class="text-blue-300 font-bold tracking-wider uppercase text-sm mb-4 block">{data.heroEyebrow}</span>
      )}
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight max-w-3xl">{data.heroHeadline}</h1>
      <p class="text-xl text-blue-100 mb-8 leading-relaxed max-w-2xl">
        {data.heroSubheadline}
      </p>
      <a href="#book" class="bg-white text-blue-900 font-bold px-8 py-3 rounded-md shadow-lg hover:bg-blue-50 transition inline-block">
        {data.ctaTitle || `Book an Evaluation`}
      </a>
    </div>
  </section>

  {data.twoPaths && (
    <section class="py-16 px-6 max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-blue-50 border border-blue-100 p-8 rounded-xl">
          <h2 class="text-xl font-bold text-blue-900 mb-3">{data.twoPaths.screeningTitle}</h2>
          <p class="text-slate-700 leading-relaxed">{data.twoPaths.screeningBody}</p>
        </div>
        <div class="bg-red-50 border border-red-200 p-8 rounded-xl">
          <h2 class="text-xl font-bold text-red-900 mb-3">{data.twoPaths.symptomsTitle}</h2>
          <p class="text-red-800 leading-relaxed">{data.twoPaths.symptomsBody}</p>
        </div>
      </div>
    </section>
  )}

  <section class="py-8 px-6 max-w-4xl mx-auto">
    <div class="prose prose-lg prose-blue max-w-none text-slate-700">
      <h2 class="text-3xl font-bold text-blue-900 mb-6">What Is It?</h2>
      <Content />
    </div>
  </section>

  {data.riskFactors && data.riskFactors.length > 0 && (
    <section class="py-8 px-6 max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-blue-900 mb-6">Risk Factors</h2>
      <ul class="list-disc pl-6 space-y-2 text-slate-700">
        {data.riskFactors.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  )}

  {data.symptoms && data.symptoms.length > 0 && (
    <section class="py-8 px-6 max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-blue-900 mb-6">Symptoms</h2>
      <ul class="list-disc pl-6 space-y-2 text-slate-700">
        {data.symptoms.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  )}

  {data.treatmentOverview && data.treatmentOverview.length > 0 && (
    <section class="py-8 px-6 max-w-4xl mx-auto">
      <div class="bg-blue-50 p-8 rounded-xl border border-blue-100">
        <h2 class="text-2xl font-bold text-blue-900 mb-4">Treatment</h2>
        <ul class="space-y-3">
          {data.treatmentOverview.map((t) => (
            <li>
              <strong class="text-blue-900">{t.name}:</strong>{' '}
              <span class="text-slate-700">{t.description}</span>
            </li>
          ))}
        </ul>
        {parentService && (
          <p class="mt-6 text-sm">
            <a href={`/services/${parentService.slug}`} class="text-blue-700 font-semibold hover:underline">
              Learn more about {parentService.data.title} &rarr;
            </a>
          </p>
        )}
      </div>
    </section>
  )}

  {data.urgentScenarios && data.urgentScenarios.length > 0 && (
    <section class="py-8 px-6 max-w-4xl mx-auto">
      <div class="bg-red-50 border border-red-200 p-8 rounded-xl">
        <h3 class="text-xl font-bold text-red-900 mb-3">{data.urgentCareTitle}</h3>
        {data.urgentCareBody && <p class="text-red-800 leading-relaxed mb-4">{data.urgentCareBody}</p>}
        <ul class="list-disc pl-6 space-y-2 text-red-800">
          {data.urgentScenarios.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>
  )}

  {relatedConditionEntries.length > 0 && (
    <section class="py-12 px-6 max-w-4xl mx-auto border-t border-slate-200">
      <h2 class="text-2xl font-bold text-blue-900 mb-6">Related Conditions</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {relatedConditionEntries.map((c) => (
          <a href={`/conditions/${c.slug}`} class="block p-5 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
            <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Related Condition</p>
            <p class="font-semibold text-slate-900">{c.data.title}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <FAQAccordion entries={faqEntries} />

  <CTA
    title={data.ctaTitle || `Book an Evaluation for ${data.title}`}
    address={`${siteConfig.contact.address.street}, ${siteConfig.contact.address.locality} - ${siteConfig.contact.address.postalCode}`}
    phone={siteConfig.contact.phone}
  />
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Request Received | Crispr Eye Care">
  <div class="min-h-[60vh] flex items-center justify-center py-20 px-6">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-xl border border-slate-100 p-10 text-center">
      <div class="w-20 h-20 bg-green-100 text-green-500 rounded-full flex items-center justify-center mx-auto mb-6 text-4xl">
        ✓
      </div>
      <h1 class="text-3xl font-extrabold text-blue-900 mb-4">Request Received!</h1>
      <p class="text-slate-600 mb-8 leading-relaxed">
        Thank you for reaching out to Crispr Eye Care. Our front desk staff will contact you shortly at the phone number provided to confirm your exact appointment time.
      </p>
      <a href="/" class="inline-block bg-blue-600 text-white font-bold px-8 py-3 rounded-lg hover:bg-blue-700 transition">
        Return to Homepage
      </a>
    </div>
  </div>
</MainLayout>

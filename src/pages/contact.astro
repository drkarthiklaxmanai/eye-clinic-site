---
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../config/site.js';
---

<MainLayout title="Contact & Location | Crispr Eye Care">
  <div class="max-w-6xl mx-auto py-16 px-6">
    <h1 class="text-4xl font-extrabold text-blue-900 mb-8 text-center">Visit Crispr Eye Care</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 bg-white rounded-2xl shadow-sm border border-slate-100 p-8 md:p-12">
      <div>
        <h2 class="text-2xl font-bold mb-6">Get in Touch</h2>
        <div class="space-y-6">
          <div>
            <p class="text-sm text-slate-500 font-semibold uppercase tracking-wider mb-1">Clinic Address</p>
            <p class="text-lg text-slate-800">{siteConfig.contact.address}</p>
            <p class="text-slate-600 mt-2">Serving Ashok Nagar, Vadapalani, Virugambakkam & Ramapuram.</p>
          </div>
          <div>
            <p class="text-sm text-slate-500 font-semibold uppercase tracking-wider mb-1">Phone & Emergencies</p>
            <a href={`tel:${siteConfig.contact.phone.replace(/[^0-9+]/g, '')}`} class="text-2xl text-blue-600 font-bold hover:underline">{siteConfig.contact.phone}</a>
          </div>
          <div>
            <p class="text-sm text-slate-500 font-semibold uppercase tracking-wider mb-1">Working Hours</p>
            <p class="text-lg text-slate-800">{siteConfig.contact.workingHoursDisplay}</p>
          </div>
        </div>
      </div>

      <div class="bg-blue-50 p-8 rounded-xl">
        <h3 class="text-xl font-bold text-blue-900 mb-4">Request a Call Back</h3>
        <form class="space-y-4" action="#" method="POST" onsubmit="event.preventDefault(); alert('Form submission connected successfully!');">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
            <input type="text" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-blue-500 focus:border-blue-500" required />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Phone Number</label>
            <input type="tel" class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-blue-500 focus:border-blue-500" required />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Service Needed</label>
            <select class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-blue-500 focus:border-blue-500">
              <option>General Checkup</option>
              <option>Cataract Evaluation</option>
              <option>LASIK Consult</option>
              <option>Retina Care</option>
            </select>
          </div>
          <button type="submit" class="w-full bg-blue-600 text-white font-bold py-3 rounded-md hover:bg-blue-700 transition">Submit Request</button>
        </form>
      </div>
    </div>
  </div>
</MainLayout>


---
import MainLayout from '../../layouts/MainLayout.astro';
import CTA from '../../components/CTA.astro';
import { siteConfig } from '../../config/site.js';

const pageTitle = "LASIK & Refractive Surgery in Chennai";
const pageDescription = "Safe, evidence-based LASIK evaluation and surgery by AIIMS-trained Dr. Rajeswari in KK Nagar, Chennai. Honest candidacy assessment, no unnecessary procedures.";
---

<MainLayout title={pageTitle} description={pageDescription}>
  <section class="bg-blue-900 text-white py-20 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="md:w-1/2">
        <span class="text-blue-300 font-bold tracking-wider uppercase text-sm mb-4 block">Refractive Surgery</span>
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">LASIK & Refractive Vision Correction</h1>
        <p class="text-xl text-blue-100 mb-8 leading-relaxed">
          Reduce or eliminate your dependence on glasses and contact lenses with a safe, precisely evaluated LASIK procedure.
        </p>
        <a href="#book" class="bg-white text-blue-900 font-bold px-8 py-3 rounded-md shadow-lg hover:bg-blue-50 transition inline-block">Book a LASIK Evaluation</a>
      </div>
      <div class="md:w-1/2 w-full">
        <img
          src="/images/lasik.png"
          alt="LASIK laser eye surgery technology"
          class="rounded-2xl shadow-2xl border-4 border-white/10 w-full object-cover aspect-video"
          onerror="this.src='https://placehold.co/800x450/1e3a8a/ffffff?text=LASIK+Surgery'"
        />
      </div>
    </div>
  </section>

  <section class="py-16 px-6 max-w-4xl mx-auto">
    <div class="prose prose-lg prose-blue max-w-none text-slate-700">
      <h2 class="text-3xl font-bold text-blue-900 mb-6">What is LASIK?</h2>
      <p class="mb-6">
        LASIK (Laser-Assisted In Situ Keratomileusis) reshapes the cornea using a precisely controlled laser, correcting how light focuses onto the retina. It's used to treat myopia (nearsightedness), hyperopia (farsightedness), and astigmatism -- the procedure itself takes only minutes per eye.
      </p>

      <h2 class="text-3xl font-bold text-blue-900 mt-12 mb-6">Our Approach: Honest Candidacy Evaluation</h2>
      <p class="mb-6">
        Not everyone is a good candidate for LASIK, and a responsible evaluation is the most important step in the entire process. Before any procedure is recommended, Dr. Rajeswari performs detailed corneal mapping and a comprehensive eye health assessment -- if LASIK isn't right for you, you'll be told clearly, along with what alternatives may suit you better.
      </p>

      <div class="bg-blue-50 p-8 rounded-xl border border-blue-100 my-10">
        <h3 class="text-xl font-bold text-blue-900 mb-4">What to Expect:</h3>
        <ul class="list-disc pl-6 space-y-2 font-medium">
          <li><strong>Comprehensive Evaluation:</strong> Corneal thickness and topography mapping to confirm safety and suitability.</li>
          <li><strong>Quick Procedure:</strong> The laser treatment itself typically takes under 15 minutes for both eyes.</li>
          <li><strong>Rapid Visual Recovery:</strong> Many patients notice significantly improved vision within 24 hours.</li>
          <li><strong>No Stitches:</strong> A minimally invasive, outpatient procedure with same-day discharge.</li>
        </ul>
      </div>

      <h2 class="text-3xl font-bold text-blue-900 mt-12 mb-6">Who Should Consider LASIK?</h2>
      <ul class="list-disc pl-6 space-y-2 mb-10">
        <li>Stable glasses/contact lens prescription for at least 1 year</li>
        <li>Age 18 or older, with healthy corneas confirmed on evaluation</li>
        <li>No significant dry eye disease or certain corneal conditions (assessed during evaluation)</li>
        <li>Realistic expectations about outcomes, discussed openly during consultation</li>
      </ul>
    </div>
  </section>

  <CTA
    title="Book Your LASIK Evaluation"
    address={`${siteConfig.contact.address.street}, ${siteConfig.contact.address.locality} - ${siteConfig.contact.address.postalCode}`}
    phone={siteConfig.contact.phone}
  />
</MainLayout>

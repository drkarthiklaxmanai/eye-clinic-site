---
import MainLayout from '../../layouts/MainLayout.astro';
import CTA from '../../components/CTA.astro';
import { siteConfig } from '../../config/site.js';

const pageTitle = "Squint (Strabismus) Treatment for Children & Adults";
const pageDescription = "Squint and strabismus correction by AIIMS-trained Dr. Rajeswari in KK Nagar, Chennai. Evaluation and treatment for children and adults.";
---

<MainLayout title={pageTitle} description={pageDescription}>
  <section class="bg-blue-900 text-white py-20 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="md:w-1/2">
        <span class="text-blue-300 font-bold tracking-wider uppercase text-sm mb-4 block">Strabismus Specialist</span>
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">Squint Evaluation & Correction</h1>
        <p class="text-xl text-blue-100 mb-8 leading-relaxed">
          Specialized care for eye misalignment in children and adults -- the earlier it's addressed, the better the outcome.
        </p>
        <a href="#book" class="bg-white text-blue-900 font-bold px-8 py-3 rounded-md shadow-lg hover:bg-blue-50 transition inline-block">Book a Squint Evaluation</a>
      </div>
      <div class="md:w-1/2 w-full">
        <img
          src="/images/squint-service.png"
          alt="Eye alignment examination"
          class="rounded-2xl shadow-2xl border-4 border-white/10 w-full object-cover aspect-video"
          onerror="this.src='https://placehold.co/800x450/1e3a8a/ffffff?text=Squint+Care'"
        />
      </div>
    </div>
  </section>

  <section class="py-16 px-6 max-w-4xl mx-auto">
    <div class="prose prose-lg prose-blue max-w-none text-slate-700">

      <h2 class="text-3xl font-bold text-blue-900 mb-6">Could This Be You or Your Child?</h2>
      <p class="mb-6">
        Squint (strabismus) is a misalignment of the eyes that can affect appearance, depth perception, and -- in children -- normal visual development. Consider an evaluation if you notice:
      </p>
      <ul class="list-disc pl-6 space-y-2 mb-10">
        <li>One or both eyes turning inward, outward, up, or down, constantly or intermittently</li>
        <li>A child tilting or turning their head to see better</li>
        <li>Double vision, or vision that seems to "compete" between the two eyes</li>
        <li>A "lazy eye" diagnosis in childhood that was never fully treated</li>
        <li>Eye strain, fatigue, or headaches with near work</li>
      </ul>

      <div class="bg-red-50 border border-red-200 p-8 rounded-xl my-10">
        <h3 class="text-xl font-bold text-red-900 mb-3">Why Early Detection Matters</h3>
        <p class="text-red-800 leading-relaxed">
          In children, untreated squint can lead to <strong>amblyopia ("lazy eye")</strong> -- permanent reduced vision in the misaligned eye, because the brain learns to ignore its input during critical developmental years. The earlier this is caught and treated, the more likely vision develops normally in both eyes.
        </p>
      </div>

      <h2 class="text-3xl font-bold text-blue-900 mt-12 mb-6">Our Diagnostic & Treatment Approach</h2>
      <p class="mb-6">
        Evaluation includes assessing the type and degree of misalignment, checking for any underlying refractive error, and determining whether amblyopia is present. Treatment is matched to the specific cause -- not every squint requires surgery.
      </p>

      <div class="bg-blue-50 p-8 rounded-xl border border-blue-100 my-10">
        <h3 class="text-xl font-bold text-blue-900 mb-4">Treatment Options:</h3>
        <ul class="list-disc pl-6 space-y-2 font-medium">
          <li><strong>Corrective Glasses:</strong> Many cases, especially in children, improve significantly with the right prescription alone.</li>
          <li><strong>Eye Patching / Vision Therapy:</strong> To strengthen a weaker eye and encourage normal visual development.</li>
          <li><strong>Strabismus Surgery:</strong> For cases where muscle realignment is needed, performed with precision for both function and appearance.</li>
          <li><strong>Adult Strabismus Care:</strong> Evaluation and treatment for misalignment that develops or persists into adulthood.</li>
        </ul>
      </div>

    </div>
  </section>

  <section class="py-12 px-6 max-w-4xl mx-auto border-t border-slate-200">
    <h2 class="text-2xl font-bold text-blue-900 mb-6">Related Reading</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="/services/neuro" class="block p-5 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Related Service</p>
        <p class="font-semibold text-slate-900">Neuro-Ophthalmology</p>
      </a>
      <a href="/dr-rajeswari" class="block p-5 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">About</p>
        <p class="font-semibold text-slate-900">Meet Dr. Rajeswari</p>
      </a>
    </div>
  </section>

  <CTA
    title="Schedule a Squint Evaluation"
    address={`${siteConfig.contact.address.street}, ${siteConfig.contact.address.locality} - ${siteConfig.contact.address.postalCode}`}
    phone={siteConfig.contact.phone}
  />
</MainLayout>

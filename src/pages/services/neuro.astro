---
import MainLayout from '../../layouts/MainLayout.astro';
import CTA from '../../components/CTA.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { siteConfig } from '../../config/site.js';

const pageTitle = "Neuro-Ophthalmology: Optic Nerve & Vision-Brain Disorders";
const pageDescription = "Expert neuro-ophthalmology care for optic nerve and brain-related vision disorders by AIIMS-trained, FAICO-certified Dr. Rajeswari in KK Nagar, Chennai.";
---

<MainLayout title={pageTitle} description={pageDescription}>
  <Breadcrumbs items={[
    { name: "Services", url: "/#services" },
    { name: "Neuro-Ophthalmology", url: "/services/neuro" }
  ]} />
  <section class="bg-blue-900 text-white py-20 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="md:w-1/2">
        <span class="text-blue-300 font-bold tracking-wider uppercase text-sm mb-4 block">FAICO-Certified Specialist</span>
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">Neuro-Ophthalmology Care</h1>
        <p class="text-xl text-blue-100 mb-8 leading-relaxed">
          Specialized diagnosis and management of complex vision problems rooted in the optic nerve and brain.
        </p>
        <a href="#book" class="bg-white text-blue-900 font-bold px-8 py-3 rounded-md shadow-lg hover:bg-blue-50 transition inline-block">Book a Neuro-Ophthalmology Consult</a>
      </div>
      <div class="md:w-1/2 w-full">
        <img
          src="/images/neuro-service.png"
          alt="Optic pathway and neuro-ophthalmology illustration"
          class="rounded-2xl shadow-2xl border-4 border-white/10 w-full object-cover aspect-video"
          onerror="this.src='https://placehold.co/800x450/1e3a8a/ffffff?text=Neuro-Ophthalmology'"
        />
      </div>
    </div>
  </section>

  <section class="py-16 px-6 max-w-4xl mx-auto">
    <div class="prose prose-lg prose-blue max-w-none text-slate-700">

      <h2 class="text-3xl font-bold text-blue-900 mb-6">Could This Be You?</h2>
      <p class="mb-6">
        Neuro-ophthalmology covers vision problems that originate in the optic nerve or the brain's visual pathways, rather than the eye itself. An evaluation may be appropriate if you experience:
      </p>
      <ul class="list-disc pl-6 space-y-2 mb-10">
        <li>Sudden or unexplained vision loss in one or both eyes</li>
        <li>Double vision that doesn't resolve, especially if new or worsening</li>
        <li>Visual field loss -- missing patches of vision you may not have noticed yourself</li>
        <li>Unexplained headaches accompanied by visual disturbance</li>
        <li>Drooping eyelid or abnormal pupil size/reaction to light</li>
        <li>A known neurological condition (e.g., MS, pituitary tumor) affecting vision</li>
      </ul>

      <div class="bg-red-50 border border-red-200 p-8 rounded-xl my-10">
        <h3 class="text-xl font-bold text-red-900 mb-3">Why Early Detection Matters</h3>
        <p class="text-red-800 leading-relaxed">
          Vision changes from neuro-ophthalmic conditions can be an early warning sign of a <strong>broader neurological issue</strong> -- some, like sudden optic nerve swelling, require prompt diagnosis to rule out serious underlying causes. Timely evaluation can both protect vision and help catch conditions elsewhere in the body.
        </p>
      </div>

      <h2 class="text-3xl font-bold text-blue-900 mt-12 mb-6">Our Diagnostic & Treatment Approach</h2>
      <p class="mb-6">
        Dr. Rajeswari holds a FAICO fellowship in Neuro-ophthalmology, the specialized training needed to evaluate vision problems that don't fit a typical eye diagnosis. Assessment includes detailed visual field testing, optic nerve evaluation, and coordination with neurology where needed.
      </p>

      <div class="bg-blue-50 p-8 rounded-xl border border-blue-100 my-10">
        <h3 class="text-xl font-bold text-blue-900 mb-4">What We Evaluate & Manage:</h3>
        <ul class="list-disc pl-6 space-y-2 font-medium">
          <li><strong>Optic Neuritis & Optic Nerve Disorders:</strong> Inflammation or damage affecting the nerve that carries visual signals to the brain.</li>
          <li><strong>Visual Field Defects:</strong> Vision loss patterns linked to brain or nerve pathway issues.</li>
          <li><strong>Double Vision (Diplopia):</strong> Evaluation of nerve or muscle causes affecting eye coordination.</li>
          <li><strong>Coordinated Specialist Referral:</strong> When findings indicate a broader neurological evaluation is needed.</li>
        </ul>
      </div>

    </div>
  </section>

  <section class="py-12 px-6 max-w-4xl mx-auto border-t border-slate-200">
    <h2 class="text-2xl font-bold text-blue-900 mb-6">Related Reading</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="/services/squint" class="block p-5 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Related Service</p>
        <p class="font-semibold text-slate-900">Squint Treatment</p>
      </a>
      <a href="/services/retina" class="block p-5 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Related Service</p>
        <p class="font-semibold text-slate-900">Retina Care</p>
      </a>
    </div>
  </section>

  <CTA
    title="Schedule a Neuro-Ophthalmology Consult"
    address={`${siteConfig.contact.address.street}, ${siteConfig.contact.address.locality} - ${siteConfig.contact.address.postalCode}`}
    phone={siteConfig.contact.phone}
  />
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../config/site.js';
---

<MainLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="min-h-[60vh] flex items-center justify-center px-6 py-20">
    <div class="max-w-lg mx-auto text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-blue-50 text-blue-600 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="8" y1="12" x2="16" y2="12"/>
        </svg>
      </div>

      <h1 class="text-3xl md:text-4xl font-extrabold text-blue-900 mb-3 tracking-tight">Page Not Found</h1>
      <p class="text-slate-600 text-lg mb-8 leading-relaxed">
        The page you're looking for doesn't exist or may have moved. Let's get you back on track.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="w-full sm:w-auto bg-blue-600 text-white font-bold px-8 py-3 rounded-xl shadow-md hover:bg-blue-700 transition-colors text-center">
          Go to Homepage
        </a>
        <a href={`tel:${siteConfig.contact.phone.replace(/[^0-9+]/g, '')}`} class="w-full sm:w-auto bg-white text-blue-700 border border-blue-200 font-bold px-8 py-3 rounded-xl hover:bg-blue-50 transition-colors text-center">
          Call Us: {siteConfig.contact.phone}
        </a>
      </div>

      <div class="mt-10 pt-8 border-t border-slate-200">
        <p class="text-sm text-slate-500 mb-3 font-semibold uppercase tracking-wider">Popular Pages</p>
        <div class="flex flex-wrap justify-center gap-3 text-sm">
          <a href="/services/cataract" class="text-blue-600 hover:underline">Cataract Surgery</a>
          <span class="text-slate-300">&middot;</span>
          <a href="/services/lasik" class="text-blue-600 hover:underline">LASIK</a>
          <span class="text-slate-300">&middot;</span>
          <a href="/dr-rajeswari" class="text-blue-600 hover:underline">Dr. Rajeswari</a>
          <span class="text-slate-300">&middot;</span>
          <a href="/book" class="text-blue-600 hover:underline">Book Appointment</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

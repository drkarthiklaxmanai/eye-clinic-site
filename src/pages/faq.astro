---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const pageTitle = "Frequently Asked Questions";
const pageDescription = "Answers to common questions about cataract surgery, LASIK, retina care, glaucoma, squint treatment, and neuro-ophthalmology at Crispr Eye Care, Chennai.";

const allFaqs = await getCollection('faqs');
const sortedFaqs = allFaqs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": sortedFaqs.map((faq) => ({
    "@type": "Question",
    "name": faq.data.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.body,
    },
  })),
};
---

<MainLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="bg-blue-900 text-white py-16 px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Frequently Asked Questions</h1>
      <p class="text-xl text-blue-200">Answers to common questions about your eye care.</p>
    </div>
  </section>

  <section class="py-16 px-6 max-w-3xl mx-auto">
    <div class="space-y-4">
      {sortedFaqs.map((faq) => (
        <details class="group bg-slate-50 rounded-lg border border-slate-200 overflow-hidden">
          <summary class="flex items-center justify-between cursor-pointer p-6 font-bold text-lg text-slate-900 group-hover:text-blue-600 transition">
            {faq.data.question}
            <span class="transition group-open:rotate-180 shrink-0 ml-4">
              <svg fill="none" height="24" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <div class="p-6 pt-0 text-slate-600 leading-relaxed border-t border-slate-100 mt-2">
            {faq.body}
          </div>
        </details>
      ))}
    </div>
  </section>
</MainLayout>

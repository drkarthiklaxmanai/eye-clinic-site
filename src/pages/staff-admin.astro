---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Staff Admin" description="Internal content management">
  <div class="max-w-4xl mx-auto py-16 px-6">
    <h1 class="text-3xl font-extrabold text-blue-900 mb-2">Staff Admin</h1>
    <p class="text-slate-600 mb-10">Manage blog posts and FAQs. All changes create a Pull Request for review before going live.</p>

    <!-- Password gate -->
    <div id="passwordGate" class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8 max-w-md">
      <label class="block text-sm font-medium text-slate-700 mb-2">Admin Password</label>
      <input
        type="password"
        id="passwordInput"
        class="w-full px-4 py-2 border border-slate-300 rounded-md focus:ring-blue-500 focus:border-blue-500 mb-4"
      />
      <button id="unlockBtn" class="w-full bg-blue-600 text-white font-bold py-2.5 rounded-md hover:bg-blue-700 transition">
        Unlock
      </button>
      <p id="unlockError" class="hidden text-red-600 text-sm mt-3"></p>
    </div>

    <!-- Main panel, hidden until unlocked -->
    <div id="adminPanel" class="hidden space-y-10">

      <div class="flex gap-3 border-b border-slate-200">
        <button id="tabBlog" class="px-4 py-2 font-semibold text-blue-600 border-b-2 border-blue-600">Blog Posts</button>
        <button id="tabFaq" class="px-4 py-2 font-semibold text-slate-500">FAQs</button>
      </div>

      <!-- BLOG SECTION -->
      <div id="blogSection">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-bold text-slate-900">Existing Blog Posts</h2>
          <button id="newBlogBtn" class="bg-blue-900 text-white font-semibold px-4 py-2 rounded-md hover:bg-blue-800 transition text-sm">
            + New Blog Post
          </button>
        </div>
        <div id="blogList" class="space-y-2 mb-8">
          <p class="text-slate-400 text-sm">Loading...</p>
        </div>

        <form id="blogForm" class="hidden space-y-4 bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
          <input type="hidden" name="_filePath" />
          <input type="hidden" name="_sha" />
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Title *</label>
            <input type="text" name="title" required class="w-full px-4 py-2 border border-slate-300 rounded-md" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Description (SEO meta) *</label>
            <textarea name="description" required rows="2" class="w-full px-4 py-2 border border-slate-300 rounded-md"></textarea>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Publish Date *</label>
            <input type="date" name="pubDate" required class="w-full px-4 py-2 border border-slate-300 rounded-md" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Author</label>
            <input type="text" name="author" placeholder="Dr. Rajeswari" class="w-full px-4 py-2 border border-slate-300 rounded-md" />
          </div>

          <!-- Tag list UI: add/remove tags individually, no free-text comma parsing -->
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Tags</label>
            <div class="flex gap-2 mb-2">
              <input type="text" id="blogTagInput" placeholder="Type a tag and press Add" class="flex-grow px-4 py-2 border border-slate-300 rounded-md" />
              <button type="button" id="blogTagAddBtn" class="bg-slate-700 text-white font-semibold px-4 py-2 rounded-md hover:bg-slate-800 transition">Add</button>
            </div>
            <div id="blogTagChips" class="flex flex-wrap gap-2"></div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Body (Markdown) *</label>
            <textarea name="body" required rows="12" class="w-full px-4 py-2 border border-slate-300 rounded-md font-mono text-sm"></textarea>
          </div>
          <div class="flex gap-3">
            <button type="submit" class="bg-blue-900 text-white font-bold px-6 py-3 rounded-md hover:bg-blue-800 transition">
              Save (Create Pull Request)
            </button>
            <button type="button" id="cancelBlogBtn" class="bg-slate-100 text-slate-700 font-semibold px-6 py-3 rounded-md hover:bg-slate-200 transition">
              Cancel
            </button>
            <button type="button" id="deleteBlogBtn" class="hidden bg-red-50 text-red-600 font-semibold px-6 py-3 rounded-md hover:bg-red-100 transition ml-auto">
              Delete This Post
            </button>
          </div>
        </form>
      </div>

      <!-- FAQ SECTION -->
      <div id="faqSection" class="hidden">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-bold text-slate-900">Existing FAQs</h2>
          <button id="newFaqBtn" class="bg-blue-900 text-white font-semibold px-4 py-2 rounded-md hover:bg-blue-800 transition text-sm">
            + New FAQ
          </button>
        </div>
        <div id="faqList" class="space-y-2 mb-8">
          <p class="text-slate-400 text-sm">Loading...</p>
        </div>

        <form id="faqForm" class="hidden space-y-4 bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
          <input type="hidden" name="_filePath" />
          <input type="hidden" name="_sha" />
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Question *</label>
            <input type="text" name="question" required class="w-full px-4 py-2 border border-slate-300 rounded-md" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Display Order</label>
            <input type="number" name="order" placeholder="1" class="w-full px-4 py-2 border border-slate-300 rounded-md" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Answer (Markdown) *</label>
            <textarea name="body" required rows="8" class="w-full px-4 py-2 border border-slate-300 rounded-md font-mono text-sm"></textarea>
          </div>
          <div class="flex gap-3">
            <button type="submit" class="bg-blue-900 text-white font-bold px-6 py-3 rounded-md hover:bg-blue-800 transition">
              Save (Create Pull Request)
            </button>
            <button type="button" id="cancelFaqBtn" class="bg-slate-100 text-slate-700 font-semibold px-6 py-3 rounded-md hover:bg-slate-200 transition">
              Cancel
            </button>
            <button type="button" id="deleteFaqBtn" class="hidden bg-red-50 text-red-600 font-semibold px-6 py-3 rounded-md hover:bg-red-100 transition ml-auto">
              Delete This FAQ
            </button>
          </div>
        </form>
      </div>

      <div id="resultBox" class="hidden p-6 rounded-xl"></div>
    </div>

  </div>
</MainLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    let adminPassword = '';
    let blogTags: string[] = [];

    const passwordGate = document.getElementById('passwordGate');
    const adminPanel = document.getElementById('adminPanel');
    const passwordInput = document.getElementById('passwordInput') as HTMLInputElement;
    const unlockBtn = document.getElementById('unlockBtn');
    const unlockError = document.getElementById('unlockError');

    const tabBlog = document.getElementById('tabBlog');
    const tabFaq = document.getElementById('tabFaq');
    const blogSection = document.getElementById('blogSection');
    const faqSection = document.getElementById('faqSection');

    const blogList = document.getElementById('blogList');
    const faqList = document.getElementById('faqList');
    const blogForm = document.getElementById('blogForm') as HTMLFormElement;
    const faqForm = document.getElementById('faqForm') as HTMLFormElement;

    const newBlogBtn = document.getElementById('newBlogBtn');
    const newFaqBtn = document.getElementById('newFaqBtn');
    const cancelBlogBtn = document.getElementById('cancelBlogBtn');
    const cancelFaqBtn = document.getElementById('cancelFaqBtn');
    const deleteBlogBtn = document.getElementById('deleteBlogBtn');
    const deleteFaqBtn = document.getElementById('deleteFaqBtn');

    const blogTagInput = document.getElementById('blogTagInput') as HTMLInputElement;
    const blogTagAddBtn = document.getElementById('blogTagAddBtn');
    const blogTagChips = document.getElementById('blogTagChips');

    const resultBox = document.getElementById('resultBox');

    function showResult(message: string, isError = false) {
      resultBox?.classList.remove('hidden', 'bg-red-50', 'bg-green-50', 'bg-slate-100');
      resultBox?.classList.add(isError ? 'bg-red-50' : 'bg-green-50');
      resultBox.innerHTML = message;
    }

    // ---- Tag chip UI ----
    function renderTagChips() {
      if (!blogTagChips) return;
      blogTagChips.innerHTML = '';
      blogTags.forEach((tag, index) => {
        const chip = document.createElement('span');
        chip.className = 'inline-flex items-center gap-2 bg-blue-50 text-blue-800 text-sm font-semibold px-3 py-1.5 rounded-full';
        chip.innerHTML = `${tag} <button type="button" class="text-blue-400 hover:text-blue-700 font-bold" aria-label="Remove">&times;</button>`;
        chip.querySelector('button')?.addEventListener('click', () => {
          blogTags.splice(index, 1);
          renderTagChips();
        });
        blogTagChips.appendChild(chip);
      });
    }

    function addTagFromInput() {
      const value = blogTagInput.value.trim();
      if (value.length === 0) return;
      if (!blogTags.includes(value)) blogTags.push(value);
      blogTagInput.value = '';
      renderTagChips();
    }

    blogTagAddBtn?.addEventListener('click', addTagFromInput);
    blogTagInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        addTagFromInput();
      }
    });

    // ---- Unlock ----
    unlockBtn?.addEventListener('click', async () => {
      if (!passwordInput.value) {
        unlockError.textContent = 'Please enter a password.';
        unlockError.classList.remove('hidden');
        return;
      }
      adminPassword = passwordInput.value;
      passwordGate?.classList.add('hidden');
      adminPanel?.classList.remove('hidden');
      await loadList('blog');
      await loadList('faq');
    });

    // ---- Tabs ----
    tabBlog?.addEventListener('click', () => {
      blogSection?.classList.remove('hidden');
      faqSection?.classList.add('hidden');
      tabBlog.classList.add('text-blue-600', 'border-b-2', 'border-blue-600');
      tabFaq?.classList.remove('text-blue-600', 'border-b-2', 'border-blue-600');
      tabFaq?.classList.add('text-slate-500');
    });

    tabFaq?.addEventListener('click', () => {
      faqSection?.classList.remove('hidden');
      blogSection?.classList.add('hidden');
      tabFaq.classList.add('text-blue-600', 'border-b-2', 'border-blue-600');
      tabBlog?.classList.remove('text-blue-600', 'border-b-2', 'border-blue-600');
      tabBlog?.classList.add('text-slate-500');
    });

    // ---- Load lists ----
    async function loadList(contentType: 'blog' | 'faq') {
      const listEl = contentType === 'blog' ? blogList : faqList;
      try {
        const response = await fetch('/.netlify/functions/list-content', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: adminPassword, contentType, action: 'list' }),
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || 'Failed to load list');

        if (data.items.length === 0) {
          listEl.innerHTML = '<p class="text-slate-400 text-sm">No items yet.</p>';
          return;
        }

        listEl.innerHTML = '';
        data.items.forEach((item: { name: string; path: string }) => {
          const row = document.createElement('div');
          row.className = 'flex justify-between items-center bg-white border border-slate-200 rounded-lg px-4 py-3';
          row.innerHTML = `
            <span class="text-sm font-medium text-slate-800">${item.name}</span>
            <button class="text-blue-600 text-sm font-semibold hover:underline" data-path="${item.path}">Edit</button>
          `;
          row.querySelector('button')?.addEventListener('click', () => openForEdit(contentType, item.path));
          listEl.appendChild(row);
        });
      } catch (error: any) {
        listEl.innerHTML = `<p class="text-red-600 text-sm">${error.message}</p>`;
      }
    }

    // ---- Open form for new item ----
    newBlogBtn?.addEventListener('click', () => {
      blogForm.reset();
      (blogForm.querySelector('[name="_filePath"]') as HTMLInputElement).value = '';
      (blogForm.querySelector('[name="_sha"]') as HTMLInputElement).value = '';
      blogTags = [];
      renderTagChips();
      deleteBlogBtn?.classList.add('hidden');
      blogForm.classList.remove('hidden');
    });

    newFaqBtn?.addEventListener('click', () => {
      faqForm.reset();
      (faqForm.querySelector('[name="_filePath"]') as HTMLInputElement).value = '';
      (faqForm.querySelector('[name="_sha"]') as HTMLInputElement).value = '';
      deleteFaqBtn?.classList.add('hidden');
      faqForm.classList.remove('hidden');
    });

    cancelBlogBtn?.addEventListener('click', () => blogForm.classList.add('hidden'));
    cancelFaqBtn?.addEventListener('click', () => faqForm.classList.add('hidden'));

    // ---- Open form for editing an existing item ----
    async function openForEdit(contentType: 'blog' | 'faq', filePath: string) {
      try {
        const response = await fetch('/.netlify/functions/list-content', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: adminPassword, contentType, action: 'get', filePath }),
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || 'Failed to load item');

        const { frontmatter, body } = parseFrontmatter(data.content);
        const form = contentType === 'blog' ? blogForm : faqForm;
        const deleteBtn = contentType === 'blog' ? deleteBlogBtn : deleteFaqBtn;

        form.reset();

        if (contentType === 'blog') {
          blogTags = Array.isArray(frontmatter.tags) ? frontmatter.tags : [];
          renderTagChips();
        }

        Object.entries(frontmatter).forEach(([key, value]) => {
          if (key === 'tags') return; // handled separately via chip UI
          const field = form.querySelector(`[name="${key}"]`) as HTMLInputElement;
          if (field) field.value = String(value);
        });
        (form.querySelector('[name="body"]') as HTMLTextAreaElement).value = body;
        (form.querySelector('[name="_filePath"]') as HTMLInputElement).value = filePath;
        (form.querySelector('[name="_sha"]') as HTMLInputElement).value = data.sha;

        deleteBtn?.classList.remove('hidden');
        form.classList.remove('hidden');
        form.scrollIntoView({ behavior: 'smooth' });
      } catch (error: any) {
        showResult(`❌ ${error.message}`, true);
      }
    }

    // Strict frontmatter parser: properly handles quoted strings and
    // JSON-style arrays, rather than naive string splitting.
    function parseFrontmatter(raw: string) {
      const match = raw.match(/^---\n([\s\S]*?)\n---\n*([\s\S]*)$/);
      if (!match) return { frontmatter: {}, body: raw };
      const [, fm, body] = match;
      const frontmatter: Record<string, any> = {};

      fm.split('\n').forEach((line) => {
        const idx = line.indexOf(':');
        if (idx === -1) return;
        const key = line.slice(0, idx).trim();
        let rawValue = line.slice(idx + 1).trim();

        if (rawValue.startsWith('[') && rawValue.endsWith(']')) {
          // Parse as a JSON array of strings
          try {
            frontmatter[key] = JSON.parse(rawValue);
          } catch {
            frontmatter[key] = [];
          }
        } else if (rawValue.startsWith('"') && rawValue.endsWith('"')) {
          try {
            frontmatter[key] = JSON.parse(rawValue);
          } catch {
            frontmatter[key] = rawValue.slice(1, -1);
          }
        } else {
          frontmatter[key] = rawValue;
        }
      });

      return { frontmatter, body: body.trim() };
    }

    // ---- Submit (create or edit) ----
    async function submitContent(contentType: 'blog' | 'faq', form: HTMLFormElement) {
      const formData = new FormData(form);
      const filePath = formData.get('_filePath') as string;
      const sha = formData.get('_sha') as string;
      formData.delete('_filePath');
      formData.delete('_sha');

      const fields: Record<string, any> = {};
      formData.forEach((value, key) => { fields[key] = value.toString(); });

      if (contentType === 'blog') {
        fields.tags = blogTags;
      }

      showResult('Validating and creating pull request...');

      try {
        const response = await fetch('/.netlify/functions/create-content', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            password: adminPassword,
            contentType,
            fields,
            action: filePath ? 'edit' : 'create',
            filePath: filePath || undefined,
            sha: sha || undefined,
          }),
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || 'Something went wrong');

        showResult(`✅ Pull request created! <a href="${data.prUrl}" target="_blank" class="text-blue-600 font-bold underline">Review and merge it here</a>`);
        form.classList.add('hidden');
      } catch (error: any) {
        showResult(`❌ ${error.message}`, true);
      }
    }

    blogForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      submitContent('blog', blogForm);
    });

    faqForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      submitContent('faq', faqForm);
    });

    // ---- Delete ----
    async function deleteItem(contentType: 'blog' | 'faq', form: HTMLFormElement) {
      const filePath = (form.querySelector('[name="_filePath"]') as HTMLInputElement).value;
      const sha = (form.querySelector('[name="_sha"]') as HTMLInputElement).value;
      if (!filePath || !sha) return;

      const confirmed = confirm('Are you sure you want to delete this? This will create a Pull Request to remove it.');
      if (!confirmed) return;

      showResult('Creating deletion pull request...');

      try {
        const response = await fetch('/.netlify/functions/create-content', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            password: adminPassword,
            contentType,
            action: 'delete',
            filePath,
            sha,
          }),
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || 'Something went wrong');

        showResult(`✅ Deletion pull request created! <a href="${data.prUrl}" target="_blank" class="text-blue-600 font-bold underline">Review and merge it here</a>`);
        form.classList.add('hidden');
      } catch (error: any) {
        showResult(`❌ ${error.message}`, true);
      }
    }

    deleteBlogBtn?.addEventListener('click', () => deleteItem('blog', blogForm));
    deleteFaqBtn?.addEventListener('click', () => deleteItem('faq', faqForm));
  });
</script>

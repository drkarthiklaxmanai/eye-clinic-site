---
import { siteConfig } from '../config/site.js';
const currentYear = new Date().getFullYear();
---
<footer class="bg-slate-900 text-slate-300 py-12 px-6">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <h3 class="text-white text-xl font-bold mb-4">{siteConfig.name}</h3>
      <p class="text-sm opacity-80 mb-4">{siteConfig.description}</p>
    </div>
    <div>
      <h4 class="text-white font-bold mb-4">Quick Links</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/services/cataract" class="hover:text-white transition">Cataract Surgery</a></li>
        <li><a href="/services/lasik" class="hover:text-white transition">LASIK & SMILE</a></li>
        <li><a href="/privacy" class="hover:text-white transition">Privacy Policy</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-white font-bold mb-4">Contact Us</h4>
      <p class="text-sm mb-2">{siteConfig.contact.address}</p>
      <p class="text-sm mb-2">Phone: <a href={`tel:${siteConfig.contact.phone.replace(/[^0-9+]/g, '')}`} class="hover:text-white">{siteConfig.contact.phone}</a></p>
      <p class="text-sm">Email: <a href={`mailto:${siteConfig.contact.email}`} class="hover:text-white">{siteConfig.contact.email}</a></p>
    </div>
  </div>
  <div class="max-w-7xl mx-auto mt-12 pt-8 border-t border-slate-800 text-sm text-center opacity-60">
    &copy; {currentYear} {siteConfig.name}. All rights reserved.
  </div>
</footer>


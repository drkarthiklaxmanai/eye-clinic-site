---
import { siteConfig } from '../config/site.js';
const currentYear = new Date().getFullYear();
---
<footer class="bg-slate-900 text-slate-300 py-16 px-6 border-t border-slate-800">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">

    <div>
      <h3 class="text-white text-2xl font-extrabold tracking-tight mb-1">{siteConfig.name}</h3>
      <p class="text-xs text-blue-400 font-semibold uppercase tracking-wider mb-4">A Unit of Crispr Speciality Clinics</p>
      <p class="text-sm opacity-80 leading-relaxed mb-4">{siteConfig.description}</p>
    </div>

    <div>
      <h4 class="text-white font-bold mb-4">Services</h4>
      <ul class="space-y-3 text-sm font-medium">
        <li><a href="/services/cataract" class="hover:text-blue-400 transition-colors">Cataract Surgery</a></li>
        <li><a href="/services/lasik" class="hover:text-blue-400 transition-colors">LASIK & SMILE</a></li>
        <li><a href="/services/retina" class="hover:text-blue-400 transition-colors">Retina Care</a></li>
        <li><a href="/services/glaucoma" class="hover:text-blue-400 transition-colors">Glaucoma Screening</a></li>
        <li><a href="/services/squint" class="hover:text-blue-400 transition-colors">Squint Treatment</a></li>
        <li><a href="/services/neuro" class="hover:text-blue-400 transition-colors">Neuro-Ophthalmology</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-white font-bold mb-4">Quick Links</h4>
      <ul class="space-y-3 text-sm font-medium">
        <li><a href="/dr-rajeswari" class="hover:text-blue-400 transition-colors">Dr. Rajeswari</a></li>
        <li><a href="/blog" class="hover:text-blue-400 transition-colors">Blog</a></li>
        <li><a href="/contact" class="hover:text-blue-400 transition-colors">Contact Us</a></li>
        <li><a href="/book" class="hover:text-blue-400 transition-colors">Book Appointment</a></li>
        <li><a href="/privacy" class="hover:text-blue-400 transition-colors">Privacy Policy</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-white font-bold mb-4">Contact Us</h4>
      <ul class="space-y-4 text-sm">
        <li class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <span class="leading-relaxed opacity-80">
            {siteConfig.contact.address.street}, {siteConfig.contact.address.locality}, {siteConfig.contact.address.city} - {siteConfig.contact.address.postalCode}
          </span>
        </li>
        <li class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <a href={`tel:${siteConfig.contact.phone.replace(/[^0-9+]/g, '')}`} class="hover:text-blue-400 font-semibold transition-colors opacity-80">{siteConfig.contact.phone}</a>
        </li>
        <li class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <a href={`mailto:${siteConfig.contact.email}`} class="hover:text-blue-400 font-semibold transition-colors opacity-80">{siteConfig.contact.email}</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="max-w-7xl mx-auto mt-16 pt-8 border-t border-slate-800 flex flex-col md:flex-row items-center justify-between gap-4 text-xs font-semibold text-slate-500">
    <p>&copy; {currentYear} {siteConfig.name}. A unit of Crispr Speciality Clinics. All rights reserved.</p>
    <p>Ethical &middot; Evidence-Based &middot; AIIMS-Trained</p>
  </div>
</footer>

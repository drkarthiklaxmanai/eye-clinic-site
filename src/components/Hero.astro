---
const { title, subtitle, doctor, credentials, ctaText, whatsappText } = Astro.props;
---

<section class="relative bg-gradient-to-br from-blue-50 via-white to-blue-50 pt-24 pb-16 md:pt-32 md:pb-24 overflow-hidden">
  <!-- Subtle background decorative blobs -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-10">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-100 rounded-full mix-blend-multiply filter blur-3xl opacity-70"></div>
    <div class="absolute top-48 -left-24 w-72 h-72 bg-indigo-100 rounded-full mix-blend-multiply filter blur-3xl opacity-70"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
      
      <!-- Left Column: Text Content -->
      <div class="lg:w-1/2 text-center lg:text-left">
        <!-- Trust Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-100 text-blue-800 font-semibold text-sm mb-6 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          {credentials}
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 leading-tight mb-6">
          <span class="block text-blue-600 mb-2">{doctor}</span>
          {title}
        </h1>
        
        <p class="text-lg md:text-xl text-slate-600 mb-8 leading-relaxed max-w-2xl mx-auto lg:mx-0">
          {subtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
          <a href="/book" class="w-full sm:w-auto bg-blue-600 text-white font-bold text-lg px-8 py-4 rounded-xl shadow-lg hover:bg-blue-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center">
            {ctaText}
          </a>
          <a href="https://wa.me/916381302828" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto bg-white text-emerald-600 border border-emerald-200 font-bold text-lg px-8 py-4 rounded-xl shadow-sm hover:bg-emerald-50 transition-all duration-300 flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            {whatsappText}
          </a>
        </div>
      </div>

      <!-- Right Column: Hero Image -->
      <div class="lg:w-1/2 relative">
        <div class="absolute inset-0 bg-blue-600 rounded-[2rem] transform rotate-3 opacity-10"></div>
        <img 
          src="/images/hero-doctor.jpg" 
          alt="Dr. Rajeswari - AIIMS Trained Ophthalmologist" 
          class="relative rounded-[2rem] shadow-2xl border-8 border-white w-full object-cover aspect-[4/3] z-10"
          onerror="this.src='https://placehold.co/800x600/e2e8f0/1e3a8a?text=Doctor+Photo'"
        />
        
        <!-- Floating Stat Card -->
        <div class="absolute -bottom-6 -left-6 bg-white p-4 rounded-xl shadow-xl border border-slate-100 flex items-center gap-4 z-20">
          <div class="bg-emerald-100 text-emerald-600 p-3 rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <div>
            <p class="font-extrabold text-slate-900 leading-none">Evidence-Based</p>
            <p class="text-sm text-slate-500">Ethical Treatment</p>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

---
const { icon, title, description, link } = Astro.props;
---
<a href={link} class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-lg hover:border-blue-200 transition group flex flex-col h-full">
  <!-- The set:html tells Astro to render the professional SVG graphic -->
  <div class="w-16 h-16 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition duration-300" set:html={icon} />
  
  <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-blue-600 transition">{title}</h3>
  <p class="text-slate-600 text-sm leading-relaxed mb-6 flex-grow">{description}</p>
  
  <span class="text-blue-600 font-semibold text-sm mt-auto flex items-center gap-1 group-hover:gap-2 transition-all">
    Learn More <span aria-hidden="true">&rarr;</span>
  </span>
</a>

---
const { icon, title, description, link } = Astro.props;
---
<div class="bg-white rounded-xl shadow-sm border border-slate-100 p-8 hover:shadow-md transition">
  <div class="text-4xl mb-4">{icon}</div>
  <h3 class="text-xl font-bold mb-3 text-slate-900">{title}</h3>
  <p class="text-slate-600 mb-6 line-clamp-3">{description}</p>
  <a href={link} class="text-blue-600 font-semibold hover:text-blue-800 flex items-center gap-1">
    Learn More <span aria-hidden="true">&rarr;</span>
  </a>
</div>


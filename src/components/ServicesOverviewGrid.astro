---
// Services overview grid for broad/local-intent landing pages (Eye
// Clinic KK Nagar, Eye Doctor KK Nagar) that have no single condition
// to anchor a psychology-specific block around. Reuses ServiceCard
// with the same optimized images/style as the homepage.
import ServiceCard from './ServiceCard.astro';

import cataractImg from '../assets/cataract.png';
import lasikImg from '../assets/lasik.png';
import retinaImg from '../assets/retina-service.png';
import glaucomaImg from '../assets/glaucoma-service.png';
import squintImg from '../assets/squint-service.png';
import neuroImg from '../assets/neuro-service.png';
import comprehensiveCheckupImg from '../assets/comprehensive-eye-checkup-service.png';
import pediatricImg from '../assets/pediatric-eye-care-service.png';
---

<section class="py-16 px-6 max-w-7xl mx-auto" id="services">
  <div class="text-center mb-12">
    <h2 class="text-3xl md:text-4xl font-extrabold text-blue-900 mb-4">Complete Eye Care Under One Roof</h2>
    <p class="text-lg text-slate-600 max-w-2xl mx-auto">From routine checkups to specialized surgery -- evidence-based eye care for every member of your family, right here in KK Nagar.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <ServiceCard
      image={cataractImg}
      alt="Macro view of intraocular lens"
      title="Cataract Surgery"
      description="Cataract causes blurred vision and glare. Advanced stitchless surgery restores vision safely."
      link="/services/cataract"
    />
    <ServiceCard
      image={lasikImg}
      alt="Laser eye surgery technology"
      title="LASIK Surgery"
      description="Correct refractive errors and reduce dependence on glasses with a detailed, safety-first evaluation."
      link="/services/lasik"
    />
    <ServiceCard
      image={retinaImg}
      alt="Retinal image"
      title="Retina Care"
      description="Specialized management for Diabetic Retinopathy and macular degeneration to prevent vision loss."
      link="/services/retina"
    />
    <ServiceCard
      image={glaucomaImg}
      alt="Glaucoma eye pressure screening"
      title="Glaucoma Screening"
      description="Early detection through eye pressure and optic nerve evaluation -- glaucoma is irreversible once vision is lost."
      link="/services/glaucoma"
    />
    <ServiceCard
      image={squintImg}
      alt="Eye alignment examination"
      title="Squint Treatment"
      description="Ocular alignment evaluations and surgical treatments for pediatric and adult strabismus patients."
      link="/services/squint"
    />
    <ServiceCard
      image={neuroImg}
      alt="Optic pathway illustration"
      title="Neuro-ophthalmology"
      description="Diagnosis and management of complex optic nerve and brain-related vision issues."
      link="/services/neuro"
    />
    <ServiceCard
      image={comprehensiveCheckupImg}
      alt="Comprehensive eye examination"
      title="Comprehensive Eye Checkup"
      description="A thorough evaluation of your vision and eye health, including screening for dry eye and digital strain."
      link="/services/comprehensive-eye-checkup"
    />
    <ServiceCard
      image={pediatricImg}
      alt="Pediatric eye examination"
      title="Pediatric Eye Care"
      description="Routine vision screening and management of children's eye conditions, from birth onward."
      link="/services/pediatric-eye-care"
    />
  </div>
</section>

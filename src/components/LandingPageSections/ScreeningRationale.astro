---
// src/components/LandingPageSections/ScreeningRationale.astro
//
// For "patient feels fine" pages -- the conversion barrier here is
// apathy, not decision anxiety. The job is making clear that normal
// vision does not mean normal eye health, without resorting to
// alarmism or clinical staging language.

interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
---

<section class="py-12 px-6 bg-gradient-to-br from-blue-50 to-white border-t border-slate-100">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-extrabold text-blue-900 mb-5 tracking-tight">{title}</h2>
    <p class="text-slate-700 leading-relaxed text-left sm:text-center">{body}</p>
  </div>
</section>

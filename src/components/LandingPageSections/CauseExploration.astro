---
// src/components/LandingPageSections/CauseExploration.astro
//
// Condition-specific section for symptom-intent pages where the cause
// is genuinely ambiguous to the patient (blurred vision, eye pain).
// Titles are configurable so this same component serves multiple
// symptom pages without cloning.

interface Props {
  title: string;
  causesIntro: string;
  commonCauses: string[];
  causesOutro?: string;
  urgentTitle: string;
  urgentIntro: string;
  urgentScenarios: string[];
}

const { title, causesIntro, commonCauses, causesOutro, urgentTitle, urgentIntro, urgentScenarios } = Astro.props;
---

<section class="py-12 px-6 bg-white border-t border-slate-100">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-extrabold text-blue-900 mb-4 tracking-tight">{title}</h2>
    <p class="text-slate-600 leading-relaxed mb-6">{causesIntro}</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-2">
      {commonCauses.map((cause: string) => (
        <div class="flex items-start gap-2 bg-slate-50 rounded-lg px-4 py-3">
          <span class="text-blue-500 mt-0.5">•</span>
          <span class="text-sm text-slate-700 font-medium">{cause}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-12 px-6 bg-red-50 border-t border-red-100">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-extrabold text-red-900 mb-4 tracking-tight">{urgentTitle}</h2>
    <p class="text-slate-700 leading-relaxed mb-6">{urgentIntro}</p>
    <div class="space-y-2">
      {urgentScenarios.map((scenario: string) => (
        <div class="flex items-start gap-2">
          <span class="text-red-500 mt-1 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 9v4M12 17h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/></svg>
          </span>
          <span class="text-sm text-slate-800 font-semibold">{scenario}</span>
        </div>
      ))}
    </div>
  </div>
</section>

---
// src/components/LandingPageSections/LandingHero.astro
import { siteConfig } from '../../config/site.js';

const {
  headline,
  subheadline,
  urgent = false,
} = Astro.props;

const phoneHref = `tel:${siteConfig.contact.phone.replace(/[^0-9+]/g, '')}`;
const whatsappHref = siteConfig.contact.whatsapp;
---

<section class={`relative pt-10 pb-16 md:pt-16 md:pb-24 px-6 overflow-hidden ${urgent ? 'bg-gradient-to-br from-red-50 via-white to-orange-50' : 'bg-gradient-to-br from-blue-50 via-white to-blue-50'}`}>
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-10">
    <div class={`absolute -top-24 -right-24 w-96 h-96 rounded-full mix-blend-multiply filter blur-3xl opacity-70 ${urgent ? 'bg-orange-100' : 'bg-blue-100'}`}></div>
    <div class={`absolute top-48 -left-24 w-72 h-72 rounded-full mix-blend-multiply filter blur-3xl opacity-70 ${urgent ? 'bg-red-100' : 'bg-indigo-100'}`}></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">

      <div class="lg:w-3/5 text-center lg:text-left">
        {urgent && (
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-100 text-red-800 font-bold text-sm mb-5 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/></svg>
            Seek care immediately if symptoms are severe
          </div>
        )}

        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-100 text-blue-800 font-semibold text-sm mb-5 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          AIIMS-Trained Ophthalmologist
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-900 leading-tight mb-5 tracking-tight">
          {headline}
        </h1>

        <p class="text-lg md:text-xl text-slate-600 mb-8 leading-relaxed max-w-xl mx-auto lg:mx-0">
          {subheadline}
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
          <a href={phoneHref} class="w-full sm:w-auto bg-blue-600 text-white font-bold text-lg px-8 py-4 rounded-xl shadow-lg hover:bg-blue-700 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 text-center flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call Now
          </a>
          <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto bg-white text-emerald-600 border border-emerald-200 font-bold text-lg px-8 py-4 rounded-xl shadow-sm hover:bg-emerald-50 hover:shadow-md transition-all duration-300 flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            WhatsApp Us
          </a>
        </div>

        <a href="#book" class="inline-block mt-4 text-blue-700 font-bold hover:underline text-sm">
          Or book online below ↓
        </a>
      </div>

      <div class="lg:w-2/5 relative w-full max-w-sm">
        <div class="absolute inset-0 bg-blue-600 rounded-[2rem] transform rotate-3 opacity-10"></div>
        <img
          src="/images/hero-doctor.jpg"
          alt={siteConfig.doctor.name}
          class="relative rounded-[2rem] shadow-2xl border-8 border-white w-full object-cover aspect-[4/3] z-10"
          onerror="this.src='https://placehold.co/800x600/e2e8f0/1e3a8a?text=Doctor+Photo'"
        />
        <div class="absolute -bottom-5 -left-5 bg-white p-3 rounded-xl shadow-xl border border-slate-100 flex items-center gap-3 z-20">
          <div class="bg-emerald-100 text-emerald-600 p-2.5 rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <div>
            <p class="font-extrabold text-slate-900 text-sm leading-none">Evidence-Based</p>
            <p class="text-xs text-slate-500">Ethical Treatment</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

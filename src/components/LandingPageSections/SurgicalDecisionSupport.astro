---
// src/components/LandingPageSections/SurgicalDecisionSupport.astro
//
// For surgical-decision pages (LASIK, Cataract). Supports partial
// rendering so the lens table can be placed AFTER DoctorsPerspective
// for Cataract -- patients ask "do I need surgery?" before "which
// lens?", and leading with the lens table reads like generic premium-
// upsell marketing rather than genuine decision support.

interface LensOption {
  name: string;
  benefit: string;
}

interface Props {
  suitabilityTitle?: string;
  suitabilityIntro?: string;
  evaluationSteps?: string[];
  notSuitableTitle?: string;
  notSuitableReasons?: string[];
  lensOptions?: LensOption[];
  onlyLensTable?: boolean;
}

const {
  suitabilityTitle,
  suitabilityIntro,
  evaluationSteps,
  notSuitableTitle,
  notSuitableReasons,
  lensOptions,
  onlyLensTable = false,
} = Astro.props;
---

{!onlyLensTable && suitabilityTitle && (
  <section class="py-12 px-6 bg-white border-t border-slate-100">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-extrabold text-blue-900 mb-4 tracking-tight">{suitabilityTitle}</h2>
      <p class="text-slate-600 leading-relaxed">{suitabilityIntro}</p>
    </div>
  </section>
)}

{!onlyLensTable && evaluationSteps && evaluationSteps.length > 0 && (
  <section class="py-10 px-6 bg-slate-50 border-t border-slate-200">
    <div class="max-w-2xl mx-auto">
      <h3 class="text-lg font-bold text-blue-900 mb-6 text-center">What Happens During Your Evaluation?</h3>
      <div class="flex flex-col items-center gap-2">
        {evaluationSteps.map((step: string, index: number) => (
          <>
            <div class="bg-white rounded-xl px-5 py-3 shadow-sm border border-slate-100 text-sm font-semibold text-slate-800 text-center w-full sm:w-auto">
              {step}
            </div>
            {index < evaluationSteps.length - 1 && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
            )}
          </>
        ))}
      </div>
    </div>
  </section>
)}

{!onlyLensTable && notSuitableReasons && notSuitableReasons.length > 0 && (
  <section class="py-10 px-6 bg-white border-t border-slate-100">
    <div class="max-w-2xl mx-auto">
      <h3 class="text-lg font-bold text-slate-900 mb-4 text-center">{notSuitableTitle}</h3>
      <div class="flex flex-wrap justify-center gap-2">
        {notSuitableReasons.map((reason: string) => (
          <span class="text-sm bg-slate-100 text-slate-700 px-4 py-2 rounded-full font-medium">{reason}</span>
        ))}
      </div>
    </div>
  </section>
)}

{lensOptions && lensOptions.length > 0 && (
  <section class="py-10 px-6 bg-slate-50 border-t border-slate-200">
    <div class="max-w-2xl mx-auto">
      <h3 class="text-lg font-bold text-blue-900 mb-5 text-center">Understanding Your Lens Options</h3>
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        {lensOptions.map((lens: LensOption, index: number) => (
          <div class={`flex justify-between items-center px-5 py-4 ${index < lensOptions.length - 1 ? 'border-b border-slate-100' : ''}`}>
            <span class="font-bold text-slate-900 text-sm">{lens.name}</span>
            <span class="text-sm text-slate-600 text-right">{lens.benefit}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

---
// src/components/LandingPageSections/DoctorSection.astro
import { siteConfig } from '../../config/site.js';
---

<section class="py-12 px-6 bg-white border-t border-slate-200">
  <div class="max-w-3xl mx-auto flex flex-col sm:flex-row items-center gap-6 text-center sm:text-left">
    <img
      src="/images/hero-doctor.jpg"
      alt={siteConfig.doctor.name}
      class="w-24 h-24 rounded-full object-cover border-4 border-blue-100 shrink-0"
      onerror="this.src='https://placehold.co/200x200/e2e8f0/1e3a8a?text=Dr'"
    />
    <div>
      <h3 class="text-xl font-bold text-blue-900">{siteConfig.doctor.name}</h3>
      <p class="text-sm text-blue-600 font-semibold uppercase tracking-wide mb-2">{siteConfig.doctor.specialization} &middot; AIIMS-Trained</p>
      <p class="text-slate-600 leading-relaxed">
        Dedicated to ethical, evidence-based eye care in KK Nagar, Chennai — prioritizing long-term visual health over high-volume treatment.
      </p>
    </div>
  </div>
</section>

---
// src/components/LandingPageSections/LocalAreaSection.astro
// Dedicated "Conveniently Located in KK Nagar" block for hyper-local
// pages (Eye Clinic KK Nagar, Eye Doctor KK Nagar) that need named
// landmarks and a fuller neighbourhood list than ConvenienceSection's
// compact 4-card layout can hold. Gated by data.showLocalArea -- does
// not affect any other landing page.
---

<section class="py-14 px-6 bg-white border-y border-slate-100">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-extrabold text-blue-900 mb-4 text-center tracking-tight">
      Conveniently Located in KK Nagar
    </h2>
    <p class="text-slate-600 text-center max-w-2xl mx-auto mb-8">
      We're on Double Tank Road in KK Nagar -- in the same building as Crispr Skin &amp; Hair Clinic, close to KM Hospital, PSBB School KK Nagar, Bashyam Apartments, and A.P. Super Market.
    </p>

    <div class="bg-blue-50/60 border border-blue-100 rounded-2xl p-6 md:p-8">
      <p class="text-sm font-bold text-blue-900 uppercase tracking-wider mb-3">Easy to Reach From</p>
      <div class="flex flex-wrap gap-2">
        {[
          "Ashok Nagar", "Vadapalani", "Jafferkhanpet", "West KK Nagar",
          "East KK Nagar", "Nesapakkam", "MGR Nagar", "Virugambakkam",
          "Valasaravakkam", "Ramapuram", "West Mambalam", "Kodambakkam",
        ].map((area) => (
          <span class="bg-white text-blue-800 text-sm px-3 py-1.5 rounded-full border border-blue-100 font-medium">
            {area}
          </span>
        ))}
      </div>

      <a
        href="https://www.google.com/maps/search/?api=1&query=Crispr+Eye+Care+KK+Nagar+Chennai"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block mt-6 text-blue-600 font-bold hover:underline"
      >
        Get Directions →
      </a>
    </div>
  </div>
</section>

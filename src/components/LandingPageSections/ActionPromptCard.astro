---
// src/components/LandingPageSections/ActionPromptCard.astro
//
// Universal conversion element -- a single "is this you?" prompt that
// can appear on ANY page type. Reusable across symptom, screening, and
// surgical pages alike.
import { siteConfig } from '../../config/site.js';

interface Props {
  prompt: string;
}

const { prompt } = Astro.props;
const phoneHref = `tel:${siteConfig.contact.phone.replace(/[^0-9+]/g, '')}`;
---

<section class="py-8 px-6 bg-blue-900">
  <div class="max-w-xl mx-auto text-center">
    <p class="text-blue-100 leading-relaxed mb-4">{prompt}</p>
    <a href={phoneHref} class="inline-block bg-white text-blue-900 font-bold px-6 py-3 rounded-xl shadow hover:bg-blue-50 transition-all">
      Call to Schedule
    </a>
  </div>
</section>

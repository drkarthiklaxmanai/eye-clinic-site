---
// src/components/LandingPageSections/ObjectionFAQ.astro
//
// Capped at 3. Objection-handling only ("will I be rushed," cost
// ambiguity, urgency) -- NOT clinical "what is this condition" FAQs.
// Reuses the faqs collection but filters and hard-limits.

import { getCollection } from 'astro:content';

const { topicKeywords = [] as string[] } = Astro.props;

const allFaqs = await getCollection('faqs');

let filtered = allFaqs;
if (topicKeywords.length > 0) {
  const matches = allFaqs.filter((faq) =>
    topicKeywords.some((kw) =>
      faq.data.question.toLowerCase().includes(kw.toLowerCase()) ||
      faq.body.toLowerCase().includes(kw.toLowerCase())
    )
  );
  if (matches.length > 0) filtered = matches;
}

const limited = filtered.sort((a, b) => (a.data.order || 0) - (b.data.order || 0)).slice(0, 3);
---

{limited.length > 0 && (
  <section class="py-12 px-6 bg-white border-t border-slate-100">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-xl md:text-2xl font-bold text-blue-900 mb-6 text-center">A Few Common Questions</h2>
      <div class="space-y-3">
        {limited.map((faq) => (
          <details class="group bg-slate-50 rounded-lg border border-slate-200">
            <summary class="flex items-center justify-between cursor-pointer p-4 font-semibold text-slate-900 group-hover:text-blue-600 transition text-sm">
              {faq.data.question}
              <span class="transition group-open:rotate-180 shrink-0 ml-3">
                <svg fill="none" height="18" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="18"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="p-4 pt-0 text-slate-600 text-sm leading-relaxed border-t border-slate-100 mt-2">
              {faq.body}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}

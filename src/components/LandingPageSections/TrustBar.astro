---
// src/components/LandingPageSections/TrustBar.astro
//
// IMPORTANT: Keep this strictly factual. Only verifiable, defensible claims --
// no patient counts, no star ratings, no testimonials -- unless real and
// approved. This component's copy is meant to be finalized ONCE and reused
// identically across every landing page.

const trustPoints = [
  {
    label: "AIIMS-Trained",
    sublabel: "Ophthalmologist",
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z|m9 12 2 2 4-4",
  },
  {
    label: "Evidence-Based",
    sublabel: "Ethical Treatment",
    icon: "M22 11.08V12a10 10 0 1 1-5.93-9.14|22 4 12 14.01 9 11.01",
  },
  {
    label: "No Pressure",
    sublabel: "Honest Evaluation",
    icon: "M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z",
  },
  {
    label: "KK Nagar",
    sublabel: "Chennai",
    icon: "M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z|12 13 3 3 0 1 0 0-6 3 3 0 0 0 0 6z",
  },
];
---

<div class="bg-white border-y border-slate-100 py-6 px-6">
  <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4">
    {trustPoints.map((point) => (
      <div class="flex flex-col items-center text-center gap-2 px-2">
        <div class="bg-blue-50 text-blue-600 p-3 rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            {point.icon.split('|').map((d) => <path d={d} />)}
          </svg>
        </div>
        <div>
          <p class="font-extrabold text-slate-900 text-sm leading-tight">{point.label}</p>
          <p class="text-xs text-slate-500">{point.sublabel}</p>
        </div>
      </div>
    ))}
  </div>
</div>

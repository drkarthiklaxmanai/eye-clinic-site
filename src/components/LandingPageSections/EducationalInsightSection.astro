---
// src/components/LandingPageSections/EducationalInsightSection.astro
//
// ONE reusable component for any "patient feels fine, doesn't realize
// they need screening" page -- Diabetic Eye now, Glaucoma and Retina
// later. Replaces what would otherwise be a new single-use component
// per condition. Renders a rationale, optional branching pathway, and
// optional risk-based action triggers.

interface PathwayBranch {
  finding: string;
  outcome: string;
}

interface Pathway {
  steps: string[];
  branches?: PathwayBranch[];
}

interface Props {
  title: string;
  body: string;
  personalRelevance?: string;
  pathway?: Pathway;
  prioritizeIf?: string[];
}

const { title, body, personalRelevance, pathway, prioritizeIf } = Astro.props;
---

<section class="py-12 px-6 bg-gradient-to-br from-blue-50 to-white border-t border-slate-100">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-extrabold text-blue-900 mb-5 tracking-tight">{title}</h2>
    <p class="text-slate-700 leading-relaxed text-left sm:text-center">{body}</p>
    {personalRelevance && (
      <p class="text-blue-900 font-semibold leading-relaxed mt-4 bg-blue-100 rounded-xl px-5 py-4 text-left sm:text-center">
        {personalRelevance}
      </p>
    )}
  </div>
</section>

{pathway && pathway.steps.length > 0 && (
  <section class="py-10 px-6 bg-slate-50 border-t border-slate-200">
    <div class="max-w-md mx-auto">
      <div class="flex flex-col items-center gap-2">
        {pathway.steps.map((step: string) => (
          <>
            <div class="bg-white rounded-xl px-5 py-3 shadow-sm border border-slate-100 text-sm font-semibold text-slate-800 text-center w-full">
              {step}
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
          </>
        ))}
      </div>

      {pathway.branches && pathway.branches.length > 0 && (
        <div class={`grid gap-3 ${pathway.branches.length === 2 ? 'grid-cols-2' : 'grid-cols-1'}`}>
          {pathway.branches.map((branch: PathwayBranch) => (
            <div class="flex flex-col items-center gap-2">
              <div class="bg-blue-50 border border-blue-200 rounded-xl px-3 py-2.5 text-xs font-bold text-blue-900 text-center w-full">
                {branch.finding}
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
              <div class="bg-white border border-slate-200 rounded-xl px-3 py-2.5 text-xs font-semibold text-slate-700 text-center w-full">
                {branch.outcome}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
)}

{prioritizeIf && prioritizeIf.length > 0 && (
  <section class="py-10 px-6 bg-white border-t border-slate-100">
    <div class="max-w-xl mx-auto">
      <h3 class="text-lg font-bold text-blue-900 mb-5 text-center">You Should Prioritize an Eye Examination If:</h3>
      <div class="space-y-2">
        {prioritizeIf.map((reason: string) => (
          <div class="flex items-start gap-2 bg-blue-50 rounded-lg px-4 py-3">
            <span class="text-blue-500 mt-0.5">•</span>
            <span class="text-sm text-slate-700 font-medium">{reason}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

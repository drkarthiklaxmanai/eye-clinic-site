---
// src/components/LandingPageSections/ConvenienceSection.astro
import { siteConfig } from '../../config/site.js';
---

<section class="py-14 px-6 bg-blue-50/60 border-y border-blue-100">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-extrabold text-blue-900 mb-8 tracking-tight">
      Convenient, Without Compromise
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">

      <div class="bg-white rounded-2xl p-4 shadow-sm">
        <div class="w-10 h-10 mx-auto mb-2 flex items-center justify-center rounded-full bg-blue-100 text-blue-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <p class="text-sm font-bold text-slate-900">Evening Hours</p>
        <p class="text-xs text-slate-500 mt-1">{siteConfig.contact.workingHoursDisplay}</p>
      </div>

      <div class="bg-white rounded-2xl p-4 shadow-sm">
        <div class="w-10 h-10 mx-auto mb-2 flex items-center justify-center rounded-full bg-blue-100 text-blue-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
        </div>
        <p class="text-sm font-bold text-slate-900">No Leave Needed</p>
        <p class="text-xs text-slate-500 mt-1">Most visits fit after work</p>
      </div>

      <div class="bg-white rounded-2xl p-4 shadow-sm">
        <div class="w-10 h-10 mx-auto mb-2 flex items-center justify-center rounded-full bg-blue-100 text-blue-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <p class="text-sm font-bold text-slate-900">{siteConfig.contact.address.locality}</p>
        <p class="text-xs text-slate-500 mt-1">Near Ashok Nagar, Vadapalani</p>
      </div>

      <div class="bg-white rounded-2xl p-4 shadow-sm">
        <div class="w-10 h-10 mx-auto mb-2 flex items-center justify-center rounded-full bg-blue-100 text-blue-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
        </div>
        <p class="text-sm font-bold text-slate-900">Easy Follow-Up</p>
        <p class="text-xs text-slate-500 mt-1">Same clinic, every time</p>
      </div>

    </div>
  </div>
</section>

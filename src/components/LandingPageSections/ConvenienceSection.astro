---
// src/components/LandingPageSections/ConvenienceSection.astro
//
// Promoted high in the architecture deliberately -- convenience affects
// more booking decisions than credentials. Reframed from "where we are"
// to "why coming here is genuinely easy."
---

<section class="py-14 px-6 bg-blue-50/60 border-y border-blue-100">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-extrabold text-blue-900 mb-8 tracking-tight">
      Convenient, Without Compromise
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="bg-white rounded-2xl p-4 shadow-sm">
        <p class="text-2xl mb-1">🕔</p>
        <p class="text-sm font-bold text-slate-900">Evening Hours</p>
        <p class="text-xs text-slate-500 mt-1">Mon-Sat, 5-8 PM</p>
      </div>
      <div class="bg-white rounded-2xl p-4 shadow-sm">
        <p class="text-2xl mb-1">💼</p>
        <p class="text-sm font-bold text-slate-900">No Leave Needed</p>
        <p class="text-xs text-slate-500 mt-1">Most visits fit after work</p>
      </div>
      <div class="bg-white rounded-2xl p-4 shadow-sm">
        <p class="text-2xl mb-1">📍</p>
        <p class="text-sm font-bold text-slate-900">KK Nagar</p>
        <p class="text-xs text-slate-500 mt-1">Near Ashok Nagar, Vadapalani</p>
      </div>
      <div class="bg-white rounded-2xl p-4 shadow-sm">
        <p class="text-2xl mb-1">🔄</p>
        <p class="text-sm font-bold text-slate-900">Easy Follow-Up</p>
        <p class="text-xs text-slate-500 mt-1">Same clinic, every time</p>
      </div>
    </div>
  </div>
</section>

---
// src/components/LandingPageSections/FAQSection.astro
//
// Reuses the same `faqs` content collection as the main site's FAQ.astro,
// but allows filtering to just the questions relevant to this landing page's
// topic. Falls back to showing all FAQs if no topicKeywords match, so this
// never renders empty.

import { getCollection } from 'astro:content';

const { topicKeywords = [] as string[], title = "Frequently Asked Questions" } = Astro.props;

const allFaqs = await getCollection('faqs');

let filtered = allFaqs;
if (topicKeywords.length > 0) {
  const matches = allFaqs.filter((faq) =>
    topicKeywords.some((kw) =>
      faq.data.question.toLowerCase().includes(kw.toLowerCase()) ||
      faq.body.toLowerCase().includes(kw.toLowerCase())
    )
  );
  if (matches.length > 0) filtered = matches;
}

const sortedFaqs = filtered.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": sortedFaqs.map((faq) => ({
    "@type": "Question",
    "name": faq.data.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.body,
    },
  })),
};
---

{sortedFaqs.length > 0 && (
  <>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <section class="py-12 px-6 bg-white border-t border-slate-200">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-blue-900 mb-8 text-center">{title}</h2>

        <div class="space-y-4">
          {sortedFaqs.map((faq) => (
            <details class="group bg-slate-50 rounded-lg border border-slate-200 overflow-hidden">
              <summary class="flex items-center justify-between cursor-pointer p-5 font-bold text-slate-900 group-hover:text-blue-600 transition">
                {faq.data.question}
                <span class="transition group-open:rotate-180">
                  <svg fill="none" height="20" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="20"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
              </summary>
              <div class="p-5 pt-0 text-slate-600 leading-relaxed border-t border-slate-100 mt-2">
                {faq.body}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  </>
)}

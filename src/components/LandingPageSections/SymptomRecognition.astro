---
// src/components/LandingPageSections/SymptomRecognition.astro
//
// Short, near-universal recognition trigger -- NOT an educational
// section. 3-5 bullets max. The goal is "yes, this sounds like me,"
// not teaching the visitor about their condition.

const { items = [] } = Astro.props;
---

{items.length > 0 && (
  <section class="py-10 px-6 bg-white border-t border-slate-100">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-xl md:text-2xl font-bold text-blue-900 mb-5">Does This Sound Like You?</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {items.slice(0, 5).map((item: string) => (
          <span class="inline-flex items-center gap-2 bg-blue-50 text-blue-800 px-4 py-2 rounded-full text-sm font-semibold">
            <span class="text-blue-500">✓</span> {item}
          </span>
        ))}
      </div>
    </div>
  </section>
)}

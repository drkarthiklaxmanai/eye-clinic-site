---
// src/components/LandingPageSections/BookingSection.astro
//
// Reuses RequestForm (Netlify Forms based) so there's exactly ONE
// booking/request pipeline across the whole site.
import RequestForm from '../RequestForm.astro';
---

<section id="book" class="py-12 px-6 bg-blue-900">
  <div class="max-w-2xl mx-auto text-center mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Request Your Appointment</h2>
    <p class="text-blue-200">Send your details and we'll call you back to confirm a time.</p>
  </div>
  <RequestForm />
</section>

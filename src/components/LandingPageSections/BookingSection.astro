---
// src/components/LandingPageSections/BookingSection.astro
//
// Uses the same real-time Supabase-backed BookingCalendar as /book,
// so there's exactly ONE booking pipeline across the whole site.
// Wrapper uses a light background (matching how /book presents the
// calendar) since BookingCalendar's glassy white card design loses
// contrast against a dark background.
import BookingCalendar from '../BookingCalendar.astro';
---

<section id="book" class="py-16 px-6 bg-slate-50">
  <div class="max-w-2xl mx-auto text-center mb-8">
    <h2 class="text-2xl md:text-3xl font-bold text-blue-900 mb-2">Book Your Appointment</h2>
    <p class="text-slate-600">Select an available time slot below to secure your consultation.</p>
  </div>
  <BookingCalendar />
</section>

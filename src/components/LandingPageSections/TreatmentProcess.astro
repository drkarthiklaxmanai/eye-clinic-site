---
// src/components/LandingPageSections/TreatmentProcess.astro
const { title = "What to Expect", steps = [] } = Astro.props;
---

<section class="py-12 px-6 bg-slate-50 border-t border-slate-200">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold text-blue-900 mb-8 text-center">{title}</h2>
    <div class="space-y-6">
      {steps.map((step: { title: string; description: string }, index: number) => (
        <div class="flex gap-4 items-start">
          <div class="shrink-0 w-10 h-10 rounded-full bg-blue-900 text-white font-bold flex items-center justify-center">
            {index + 1}
          </div>
          <div>
            <h3 class="font-bold text-slate-900 mb-1">{step.title}</h3>
            <p class="text-slate-600 leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

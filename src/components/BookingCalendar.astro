---
// src/components/BookingCalendar.astro
---

<div class="max-w-5xl mx-auto p-8 bg-white/40 backdrop-blur-xl border border-white/50 rounded-3xl shadow-2xl flex flex-col md:flex-row gap-8">

  <div class="md:w-1/2 space-y-5 pr-0 md:pr-8 border-b md:border-b-0 md:border-r border-slate-200/60 pb-8 md:pb-0">
    <h3 class="text-2xl font-bold text-blue-900 mb-6">Patient Details</h3>

    <div class="flex gap-3">
      <select id="prefix" class="p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none w-1/4">
        <option value="Mr.">Mr.</option>
        <option value="Ms.">Ms.</option>
        <option value="Mrs.">Mrs.</option>
        <option value="Dr.">Dr.</option>
      </select>
      <input type="text" id="firstName" placeholder="First Name" required class="p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none w-3/4" />
    </div>

    <input type="text" id="lastName" placeholder="Last Name" required class="w-full p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none" />
    <input type="tel" id="phone" placeholder="Mobile Number (+91...)" required class="w-full p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none" />

    <select id="service" class="w-full p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none">
      <option value="" disabled selected>Select Service...</option>
      <option value="General Checkup">General Eye Checkup</option>
      <option value="Cataract Evaluation">Cataract Evaluation</option>
      <option value="LASIK Screening">LASIK Screening</option>
      <option value="Retina Care">Retina Care</option>
      <option value="Glaucoma Screening">Glaucoma Screening</option>
      <option value="Squint Treatment">Squint Treatment</option>
      <option value="Neuro-Ophthalmology">Neuro-Ophthalmology</option>
    </select>
  </div>

  <div class="md:w-1/2 flex flex-col">
    <h3 class="text-2xl font-bold text-blue-900 mb-6">Select Slot</h3>

    <input type="date" id="date" required class="w-full p-3 mb-6 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none" />

    <div id="slotsContainer" class="grid grid-cols-2 gap-3 mb-8">
      <p class="col-span-2 text-slate-400 text-sm">Select a date to see available times.</p>
    </div>

    <button id="confirmBtn" class="mt-auto w-full py-4 bg-blue-900 text-white font-bold rounded-xl shadow-lg hover:bg-blue-800 transition disabled:opacity-50">
      Confirm Appointment
    </button>

    <div id="successMessage" class="hidden mt-4 text-center p-3 bg-green-100 text-green-800 rounded-lg font-medium">
      Appointment confirmed successfully!
    </div>

    <div id="errorMessage" class="hidden mt-4 text-center p-3 bg-red-100 text-red-800 rounded-lg font-medium"></div>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase.js';

  // Generates display-formatted time slots (e.g. "09:30 AM") between a
  // start and end time (24h "HH:MM:SS" from Postgres), at the given
  // duration in minutes. The last slot must still fit before end_time.
  function generateSlotsForSession(startTime: string, endTime: string, durationMinutes: number): string[] {
    const slots: string[] = [];
    const [startH, startM] = startTime.split(':').map(Number);
    const [endH, endM] = endTime.split(':').map(Number);

    let current = startH * 60 + startM;
    const end = endH * 60 + endM;

    while (current + durationMinutes <= end) {
      const h24 = Math.floor(current / 60);
      const m = current % 60;
      const period = h24 >= 12 ? 'PM' : 'AM';
      const h12 = h24 % 12 === 0 ? 12 : h24 % 12;
      slots.push(`${String(h12).padStart(2, '0')}:${String(m).padStart(2, '0')} ${period}`);
      current += durationMinutes;
    }
    return slots;
  }

// Converts a display time like "09:30 AM" back into minutes-since-midnight,
  // so it can be compared against the current time.
  function parseTimeToMinutes(displayTime: string): number {
    const [time, period] = displayTime.split(' ');
    const [hStr, mStr] = time.split(':');
    let h = parseInt(hStr, 10);
    const m = parseInt(mStr, 10);
    if (period === 'PM' && h !== 12) h += 12;
    if (period === 'AM' && h === 12) h = 0;
    return h * 60 + m;
  }

  document.addEventListener('astro:page-load', () => {
    let selectedTime = "";

    const dateInput = document.getElementById('date') as HTMLInputElement;
    const slotsContainer = document.getElementById('slotsContainer');
    const confirmBtn = document.getElementById('confirmBtn') as HTMLButtonElement;
    const successMessage = document.getElementById('successMessage');
    const errorMessage = document.getElementById('errorMessage');

    const today = new Date().toISOString().split('T')[0];
    if (dateInput) dateInput.min = today;

    function showError(message: string) {
      errorMessage.textContent = message;
      errorMessage?.classList.remove('hidden');
    }

    function renderSlots(times: string[]) {
      selectedTime = "";
      if (times.length === 0) {
        slotsContainer.innerHTML = '<p class="col-span-2 text-slate-500 text-sm">No slots available on this date. Please try another day, or call us directly.</p>';
        return;
      }
      slotsContainer.innerHTML = '';
      times.forEach((time) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'time-slot py-3 border border-blue-200 rounded-lg text-blue-800 hover:bg-blue-50 transition font-medium';
        btn.textContent = time;
        btn.dataset.time = time;
        btn.addEventListener('click', () => {
          document.querySelectorAll('.time-slot').forEach((b) => b.classList.remove('bg-blue-600', 'text-white'));
          btn.classList.add('bg-blue-600', 'text-white');
          selectedTime = time;
        });
        slotsContainer.appendChild(btn);
      });
    }

    // Fetch and combine: schedule sessions (computed into individual times)
    // + blocked dates + blocked slots + already-confirmed appointments,
    // to compute real availability.
    async function loadAvailableSlots(dateStr: string) {
      slotsContainer.innerHTML = '<p class="col-span-2 text-slate-400 text-sm">Checking availability...</p>';
      errorMessage?.classList.add('hidden');

      try {
        const dayOfWeek = new Date(dateStr + 'T00:00:00').getDay();

        // 1. Is the whole day blocked (holiday/leave)?
        const { data: blockedDateRows, error: bdError } = await supabase
          .from('blocked_dates')
          .select('reason')
          .eq('blocked_date', dateStr);
        if (bdError) throw bdError;

        if (blockedDateRows && blockedDateRows.length > 0) {
          slotsContainer.innerHTML = `<p class="col-span-2 text-slate-500 text-sm">Clinic closed on this date${blockedDateRows[0].reason ? `: ${blockedDateRows[0].reason}` : ''}. Please choose another day.</p>`;
          return;
        }

        // 2. What sessions are normally open on this day of week?
        //    Each session is a time range + slot duration -- we compute
        //    the actual bookable times from it here.
        const { data: sessionRows, error: schError } = await supabase
          .from('schedule_sessions')
          .select('start_time, end_time, slot_duration_minutes')
          .eq('day_of_week', dayOfWeek)
          .eq('is_active', true);
        if (schError) throw schError;

        let possibleTimes: string[] = [];
        (sessionRows || []).forEach((session) => {
          possibleTimes.push(...generateSlotsForSession(session.start_time, session.end_time, session.slot_duration_minutes));
        });

        if (possibleTimes.length === 0) {
          slotsContainer.innerHTML = '<p class="col-span-2 text-slate-500 text-sm">Clinic closed on this day of the week. Please choose another day.</p>';
          return;
        }

        // 3. Remove ad-hoc blocked slots for this specific date
        const { data: blockedSlotRows, error: bsError } = await supabase
          .from('blocked_slots')
          .select('time_slot')
          .eq('blocked_date', dateStr);
        if (bsError) throw bsError;

        const blockedTimes = new Set((blockedSlotRows || []).map((r) => r.time_slot));
        possibleTimes = possibleTimes.filter((t) => !blockedTimes.has(t));

        // 4. Remove already-confirmed appointment times
        const { data: takenRows, error: takenError } = await supabase
          .from('slot_availability')
          .select('appointment_time')
          .eq('appointment_date', dateStr);
        if (takenError) throw takenError;

        const takenTimes = new Set((takenRows || []).map((r) => r.appointment_time));
        possibleTimes = possibleTimes.filter((t) => !takenTimes.has(t));

        // 5. If the selected date is TODAY, remove any time slot that has
        //    already passed -- prevents booking a 10 AM slot at 2 PM.
        const todayStr = new Date().toISOString().split('T')[0];
        if (dateStr === todayStr) {
          const now = new Date();
          const currentMinutes = now.getHours() * 60 + now.getMinutes();
          possibleTimes = possibleTimes.filter((t) => parseTimeToMinutes(t) > currentMinutes);
        }

        renderSlots(possibleTimes);
      } catch (err) {
        console.error("Error loading availability:", err);
        slotsContainer.innerHTML = '<p class="col-span-2 text-red-500 text-sm">Could not load availability. Please try again.</p>';
      }
    }

    dateInput?.addEventListener('change', (e) => {
      const selectedDate = (e.target as HTMLInputElement).value;
      if (selectedDate) loadAvailableSlots(selectedDate);
    });

    if (confirmBtn) {
      confirmBtn.addEventListener('click', async () => {
        const prefix = (document.getElementById('prefix') as HTMLSelectElement).value;
        const fName = (document.getElementById('firstName') as HTMLInputElement).value;
        const lName = (document.getElementById('lastName') as HTMLInputElement).value;
        const phone = (document.getElementById('phone') as HTMLInputElement).value;
        const service = (document.getElementById('service') as HTMLSelectElement).value;
        const date = dateInput.value;

        errorMessage?.classList.add('hidden');

        if (!fName || !phone || !service || !date || !selectedTime) {
          showError("Please fill in all details and select an available time slot.");
          return;
        }

        try {
          confirmBtn.innerText = "Securing Slot...";
          confirmBtn.disabled = true;

          const { error } = await supabase.from('appointments').insert({
            prefix,
            first_name: fName,
            last_name: lName,
            phone,
            service_type: service,
            appointment_date: date,
            appointment_time: selectedTime,
          });

          if (error) {
            if (error.code === '23505') {
              throw new Error("Sorry, that slot was just booked by someone else. Please pick another time.");
            }
            throw error;
          }

          successMessage?.classList.remove('hidden');
          confirmBtn.style.display = 'none';

        } catch (err: any) {
          console.error("Error booking:", err);
          showError(err.message || "Could not complete your booking. Please try again or call us directly.");
          confirmBtn.innerText = "Confirm Appointment";
          confirmBtn.disabled = false;
        }
      });
    }
  });
</script>

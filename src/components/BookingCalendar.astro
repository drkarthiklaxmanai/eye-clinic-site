---
// src/components/BookingCalendar.astro
---

<div class="max-w-5xl mx-auto p-8 bg-white/40 backdrop-blur-xl border border-white/50 rounded-3xl shadow-2xl flex flex-col md:flex-row gap-8">

  <div class="md:w-1/2 space-y-5 pr-0 md:pr-8 border-b md:border-b-0 md:border-r border-slate-200/60 pb-8 md:pb-0">
    <h3 class="text-2xl font-bold text-blue-900 mb-6">Patient Details</h3>

    <div class="flex gap-3">
      <select id="prefix" class="p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none w-1/4">
        <option value="Mr.">Mr.</option>
        <option value="Ms.">Ms.</option>
        <option value="Mrs.">Mrs.</option>
        <option value="Dr.">Dr.</option>
      </select>
      <input type="text" id="firstName" placeholder="First Name" required class="p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none w-3/4" />
    </div>

    <input type="text" id="lastName" placeholder="Last Name" required class="w-full p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none" />
    <input type="tel" id="phone" placeholder="Mobile Number (+91...)" required class="w-full p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none" />

    <select id="service" class="w-full p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none">
      <option value="" disabled selected>Select Service...</option>
      <option value="General Checkup">General Eye Checkup</option>
      <option value="Cataract Evaluation">Cataract Evaluation</option>
      <option value="LASIK Screening">LASIK Screening</option>
      <option value="Retina Care">Retina Care</option>
      <option value="Glaucoma Screening">Glaucoma Screening</option>
      <option value="Squint Treatment">Squint Treatment</option>
      <option value="Neuro-Ophthalmology">Neuro-Ophthalmology</option>
    </select>
  </div>

  <div class="md:w-1/2 flex flex-col">
    <h3 class="text-2xl font-bold text-blue-900 mb-6">Select Slot</h3>

    <input type="date" id="date" required class="w-full p-3 mb-6 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none" />

    <div class="grid grid-cols-2 gap-3 mb-8">
      <button type="button" class="time-slot py-3 border border-blue-200 rounded-lg text-blue-800 hover:bg-blue-50 transition font-medium" data-time="10:00 AM">10:00 AM</button>
      <button type="button" class="time-slot py-3 border border-blue-200 rounded-lg text-blue-800 hover:bg-blue-50 transition font-medium" data-time="11:30 AM">11:30 AM</button>
      <button type="button" class="time-slot py-3 border border-blue-200 rounded-lg text-blue-800 hover:bg-blue-50 transition font-medium" data-time="05:00 PM">05:00 PM</button>
      <button type="button" class="time-slot py-3 border border-blue-200 rounded-lg text-blue-800 hover:bg-blue-50 transition font-medium" data-time="06:30 PM">06:30 PM</button>
    </div>

    <button id="confirmBtn" class="mt-auto w-full py-4 bg-blue-900 text-white font-bold rounded-xl shadow-lg hover:bg-blue-800 transition disabled:opacity-50">
      Confirm Appointment
    </button>

    <div id="successMessage" class="hidden mt-4 text-center p-3 bg-green-100 text-green-800 rounded-lg font-medium">
      Appointment confirmed successfully!
    </div>

    <div id="errorMessage" class="hidden mt-4 text-center p-3 bg-red-100 text-red-800 rounded-lg font-medium"></div>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase.js';

  document.addEventListener('astro:page-load', () => {
    let selectedTime = "";

    const dateInput = document.getElementById('date') as HTMLInputElement;
    const timeSlots = document.querySelectorAll('.time-slot');
    const confirmBtn = document.getElementById('confirmBtn') as HTMLButtonElement;
    const successMessage = document.getElementById('successMessage');
    const errorMessage = document.getElementById('errorMessage');

    // Set min date to today, so patients can't pick a past date
    const today = new Date().toISOString().split('T')[0];
    if (dateInput) dateInput.min = today;

    // 1. Handle Time Slot Selection Visuals
    timeSlots.forEach(slot => {
      slot.addEventListener('click', (e) => {
        timeSlots.forEach(btn => btn.classList.remove('bg-blue-600', 'text-white'));
        const target = e.target as HTMLButtonElement;
        if (target.disabled) return;
        target.classList.add('bg-blue-600', 'text-white');
        selectedTime = target.getAttribute('data-time') || "";
      });
    });

    // 2. Check availability for the selected date via the public,
    //    PII-free slot_availability view -- no auth needed to read this.
    if (dateInput) {
      dateInput.addEventListener('change', async (e) => {
        const selectedDate = (e.target as HTMLInputElement).value;

        timeSlots.forEach(slot => {
          const btn = slot as HTMLButtonElement;
          btn.disabled = false;
          btn.classList.remove('opacity-50', 'line-through', 'cursor-not-allowed', 'bg-slate-100');
        });

        try {
          const { data, error } = await supabase
            .from('slot_availability')
            .select('appointment_time')
            .eq('appointment_date', selectedDate);

          if (error) throw error;

          data?.forEach((row) => {
            const targetBtn = document.querySelector(`button[data-time="${row.appointment_time}"]`) as HTMLButtonElement;
            if (targetBtn) {
              targetBtn.disabled = true;
              targetBtn.classList.add('opacity-50', 'line-through', 'cursor-not-allowed', 'bg-slate-100');
            }
          });
        } catch (err) {
          console.error("Error checking availability:", err);
        }
      });
    }

    // 3. Submit the booking. No auth step needed -- RLS allows anonymous
    //    inserts directly. The database's unique index prevents double
    //    booking automatically, even under concurrent requests.
    if (confirmBtn) {
      confirmBtn.addEventListener('click', async () => {
        const prefix = (document.getElementById('prefix') as HTMLSelectElement).value;
        const fName = (document.getElementById('firstName') as HTMLInputElement).value;
        const lName = (document.getElementById('lastName') as HTMLInputElement).value;
        const phone = (document.getElementById('phone') as HTMLInputElement).value;
        const service = (document.getElementById('service') as HTMLSelectElement).value;
        const date = dateInput.value;

        errorMessage?.classList.add('hidden');

        if (!fName || !phone || !service || !date || !selectedTime) {
          errorMessage.textContent = "Please fill in all details and select an available time slot.";
          errorMessage?.classList.remove('hidden');
          return;
        }

        try {
          confirmBtn.innerText = "Securing Slot...";
          confirmBtn.disabled = true;

          const { error } = await supabase.from('appointments').insert({
            prefix,
            first_name: fName,
            last_name: lName,
            phone,
            service_type: service,
            appointment_date: date,
            appointment_time: selectedTime,
          });

          if (error) {
            // Postgres unique constraint violation = someone else just took this slot
            if (error.code === '23505') {
              throw new Error("Sorry, that slot was just booked by someone else. Please pick another time.");
            }
            throw error;
          }

          successMessage?.classList.remove('hidden');
          confirmBtn.style.display = 'none';

        } catch (err: any) {
          console.error("Error booking:", err);
          errorMessage.textContent = err.message || "Could not complete your booking. Please try again or call us directly.";
          errorMessage?.classList.remove('hidden');
          confirmBtn.innerText = "Confirm Appointment";
          confirmBtn.disabled = false;
        }
      });
    }
  });
</script>

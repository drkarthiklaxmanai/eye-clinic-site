---
const { title, address, phone } = Astro.props;
---
<section id="book" class="bg-slate-50 py-20 px-6 border-t border-slate-200">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-extrabold text-blue-900 mb-4">{title}</h2>
      <p class="text-lg text-slate-600">Schedule your comprehensive eye evaluation with Dr. Rajeswari today.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-5 gap-0 bg-white rounded-2xl shadow-xl overflow-hidden border border-slate-100">
      
      <div class="bg-blue-900 text-white p-10 md:col-span-2 flex flex-col justify-between">
        <div>
          <h3 class="text-2xl font-bold mb-6">Clinic Details</h3>
          <div class="space-y-6">
            <div>
              <p class="text-blue-300 text-sm font-semibold uppercase tracking-wider mb-1">Call for Appointments</p>
              <a href={`tel:${phone.replace(/[^0-9+]/g, '')}`} class="text-3xl font-bold hover:text-blue-200 transition">{phone}</a>
            </div>
            <div>
              <p class="text-blue-300 text-sm font-semibold uppercase tracking-wider mb-1">Location</p>
              <p class="text-lg opacity-90 leading-relaxed">{address}</p>
            </div>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t border-blue-800">
          <p class="text-sm opacity-80">If this is a medical emergency or you are experiencing sudden vision loss, please call the clinic immediately or visit the nearest emergency room.</p>
        </div>
      </div>

      <div class="p-10 md:col-span-3">
        <form name="appointment" method="POST" data-netlify="true" action="/success" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">Patient Name *</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition" placeholder="John Doe" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-slate-700 mb-2">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition" placeholder="+91 63813 02828" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="date" class="block text-sm font-semibold text-slate-700 mb-2">Preferred Date</label>
              <input type="date" id="date" name="date" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition" />
            </div>
            <div>
              <label for="service" class="block text-sm font-semibold text-slate-700 mb-2">Service Needed</label>
              <select id="service" name="service" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition">
                <option value="General Checkup">General Eye Checkup</option>
                <option value="Cataract">Cataract Evaluation</option>
                <option value="LASIK">LASIK / Refractive Consult</option>
                <option value="Retina">Retina Care</option>
                <option value="Squint">Squint Treatment</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-slate-700 mb-2">Message or Symptoms (Optional)</label>
            <textarea id="message" name="message" rows="3" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition" placeholder="Please describe any blurriness, pain, or specific conditions..."></textarea>
          </div>

          <div class="pt-2">
            <button type="submit" class="w-full bg-blue-600 text-white font-bold text-lg py-4 rounded-lg hover:bg-blue-700 transition shadow-md">
              Request Appointment
            </button>
            <p class="text-xs text-center text-slate-500 mt-4">By submitting this form, you agree to our privacy policy. Your data is secure.</p>
          </div>
        </form>
      </div>

    </div>
  </div>
</section>

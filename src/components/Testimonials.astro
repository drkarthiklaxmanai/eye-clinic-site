---
// You can easily add, edit, or remove reviews from this list!
const reviews = [
  {
    name: "S. Ramakrishnan",
    service: "Cataract Surgery",
    quote: "Dr. Rajeswari was incredibly thorough. She didn't rush me into surgery, but took the time to explain my condition in detail. The phaco procedure was painless, and my vision is crystal clear now. Truly AIIMS-standard care."
  },
  {
    name: "Priya V.",
    service: "LASIK Vision Correction",
    quote: "I was extremely nervous about getting LASIK, but the level of precision and ethical evaluation here put me at ease. The surgery took minutes, and waking up the next day without needing glasses felt like a miracle."
  },
  {
    name: "M. Karthik",
    service: "Retina Care",
    quote: "I have been managing diabetic retinopathy for years, and the diagnostic scans and detailed explanations provided here are world-class. I finally feel like my long-term visual health is in safe, expert hands."
  }
];
---

<section class="bg-blue-50/50 py-20 px-6 border-y border-slate-200">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-blue-900 mb-4">Patient Stories</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">Read about the experiences of patients who trusted Crispr Eye Care with their vision.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviews.map((review) => (
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 relative group hover:shadow-md hover:border-blue-200 transition-all duration-300 flex flex-col">
          <!-- Decorative Quote Icon -->
          <div class="text-blue-100 absolute top-6 right-6 group-hover:text-blue-200 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          </div>
          
          <!-- 5-Star Rating -->
          <div class="flex gap-1 mb-6 text-amber-400">
            {[...Array(5)].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          
          <!-- Quote Text -->
          <p class="text-slate-700 mb-8 relative z-10 leading-relaxed italic flex-grow">
            "{review.quote}"
          </p>
          
          <!-- Patient Info -->
          <div class="mt-auto pt-6 border-t border-slate-100">
            <p class="font-extrabold text-slate-900">{review.name}</p>
            <p class="text-sm text-blue-600 font-semibold uppercase tracking-wider mt-1">{review.service}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
import { ViewTransitions } from 'astro:transitions';
import FloatingContact from '../components/FloatingContact.astro';
import LandingFooter from '../components/LandingPageSections/LandingFooter.astro';
import { siteConfig } from '../config/site.js';
import '../styles/global.css';

// Landing pages are built for paid traffic (Google Ads). They deliberately
// have NO navbar, NO footer links, and NO exit paths -- every link off this
// page is a wasted ad click. They are also noindexed so they never compete
// with or dilute the real /services/* SEO pages in organic search.
const {
  title,
  description = siteConfig.description,
  image = '/images/hero-doctor.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://crispreyecare.com');
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />

    <ViewTransitions />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | {siteConfig.name}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Deliberately noindexed: ad landing pages should never appear in organic search -->
    <meta name="robots" content="noindex, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Crispr Eye Care`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site || 'https://crispreyecare.com')} />

    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-GR0G04EY1M"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GR0G04EY1M');
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  </head>

  <body class="bg-white text-slate-800 antialiased selection:bg-blue-200 selection:text-blue-900 flex flex-col min-h-screen" style="font-family: 'Plus Jakarta Sans', sans-serif;">

    <!-- Minimal top bar: logo + phone only. No nav links, no menu, no exit paths. -->
    <header class="w-full bg-white/90 backdrop-blur-md border-b border-slate-100 py-4 px-6 sticky top-0 z-40">
      <div class="max-w-5xl mx-auto flex justify-between items-center">
        <div class="flex flex-col">
          <span class="text-lg md:text-xl font-extrabold text-blue-900 tracking-tight leading-none">{siteConfig.name}</span>
          <span class="text-[0.6rem] font-bold text-slate-400 uppercase tracking-widest mt-0.5 hidden sm:block">A Unit of Crispr Speciality Clinics</span>
        </div>
        <a href={`tel:${siteConfig.contact.phone.replace(/[^0-9+]/g, '')}`} class="bg-blue-50 text-blue-700 font-bold text-sm md:text-base px-4 py-2 rounded-full flex items-center gap-2 hover:bg-blue-100 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 md:w-5 md:h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <span class="hidden sm:inline">{siteConfig.contact.phone}</span>
          <span class="sm:hidden">Call</span>
        </a>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <LandingFooter />

    <FloatingContact />

    <style is:global>
      h1, h2, h3, h4, h5, h6 {
        letter-spacing: -0.02em;
      }
    </style>

  </body>
</html>
